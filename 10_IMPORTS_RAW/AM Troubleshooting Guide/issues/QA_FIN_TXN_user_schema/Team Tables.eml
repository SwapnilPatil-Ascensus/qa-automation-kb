CREATE TABLE QA_FIN_TXN (

  uii_acct_id VARCHAR2(11) NOT null,

  seq_acct_id NUMBER NOT NULL,

  to_seq_acct_id NUMBER NOT null,

  traunch_id VARCHAR2(6) NOT null,

  transaction_type VARCHAR2(25) NOT null,

  transaction_sub_type VARCHAR2(50),

  original_principal NUMBER NOT null,

  original_principal_toacct NUMBER,

  new_principal NUMBER,

  seq_qa_fin_txn_id NUMBER NOT NULL,

  seq_fin_txn_id NUMBER,

  linked_txn_id NUMBER,

  seq_pay_id NUMBER,

  max_contrib_flag VARCHAR2(1),

  test_case_name VARCHAR2(255),

  ctl_ins_dttm DATE,



  CONSTRAINT SEQ_QA_FIN_TXN_ID_PK PRIMARY KEY (SEQ_QA_FIN_TXN_ID)

);



GRANT INSERT, SELECT, UPDATE ON QA_FIN_TXN TO PUBLIC;



CREATE SEQUENCE SEQ_QA_FIN_TXN_PK start with 1;



create or replace TRIGGER TRG_QA_FIN_TXN BEFORE UPDATE OR INSERT ON QA_FIN_TXN FOR EACH ROW

        BEGIN

          IF INSERTING

          THEN

             :NEW.SEQ_QA_FIN_TXN_ID := SEQ_QA_FIN_TXN_PK.NEXTVAL;

          END IF;



          :NEW.CTL_INS_DTTM := SYSTIMESTAMP;

   EXCEPTION

      WHEN OTHERS

      THEN

         RAISE_APPLICATION_ERROR (-30000,

                                  SQLERRM || TO_CHAR (SQLCODE, '09999'));

END TRG_QA_FIN_TXN;

/



SELECT *

FROM QA_FIN_TXN;



SELECT *

FROM QA_FIN_INSTRUCTION;



CREATE TABLE QA_FIN_INSTRUCTION (

  seq_qa_fin_instruction_id NUMBER,

  seq_qa_fin_txn_id NUMBER NOT NULL,

  seq_num NUMBER,

  fund_id NUMBER,

  amount_type VARCHAR2(10),

  amount NUMBER NOT NULL,

  principal_amount NUMBER,

  activity VARCHAR2(3) NOT NULL,

  fin_type VARCHAR2(9) DEFAULT 'FUND',

  comments VARCHAR(50),

  ctl_ins_dttm DATE,



  CONSTRAINT SEQ_QA_FIN_INSTR_ID_PK PRIMARY KEY (SEQ_QA_FIN_INSTRUCTION_ID),

  CONSTRAINT SEQ_QA_FIN_TXN_ID_FK FOREIGN KEY (SEQ_QA_FIN_TXN_ID) REFERENCES QA_FIN_TXN(SEQ_QA_FIN_TXN_ID)

);



GRANT INSERT, SELECT, UPDATE ON QA_FIN_INSTRUCTION TO PUBLIC;



CREATE SEQUENCE SEQ_QA_FIN_INSTR_ID_PK start with 1;



create or replace TRIGGER TRG_QA_FIN_INSTRUCTION BEFORE UPDATE OR INSERT ON QA_FIN_INSTRUCTION FOR EACH ROW

        BEGIN

          IF INSERTING

          THEN

             :NEW.SEQ_QA_FIN_INSTRUCTION_ID := SEQ_QA_FIN_INSTR_ID_PK.NEXTVAL;

          END IF;



          :NEW.CTL_INS_DTTM := SYSTIMESTAMP;

   EXCEPTION

      WHEN OTHERS

      THEN

         RAISE_APPLICATION_ERROR (-30000,

                                  SQLERRM || TO_CHAR (SQLCODE, '09999'));

END TRG_QA_FIN_INSTRUCTION;

/


Regards,
Pramod



<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite verbose="2" name="Stage2 Regression (Front Office) - Release" parallel="tests" thread-count="1">
	<listeners>
		<listener class-name="com.cs529.qa.prime.core.PrimeResourceManager"/>
	</listeners>
	
	<test name="IAD Member Enrollment - Positive Test Cases">
		<parameter name="traunch" value="iad"></parameter>
		<parameter name="features" value="frontoffice/iad/member/enrollment/feature/IAD_EnrollmentPositive.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>
	
	<test name="MID NextGen Enrollment - Positive Test Cases">

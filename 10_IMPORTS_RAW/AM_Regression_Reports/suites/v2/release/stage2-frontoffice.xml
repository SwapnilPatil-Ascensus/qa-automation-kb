	</test>
	
	<test name="ILB CSR Enrollment - Positive Test Cases">
		<parameter name="traunch" value="ilb"></parameter>
		<parameter name="features" value="frontoffice/ilb/csr/enrollment/feature/ILB_CSREnrollmentPositive.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.ParallelFeatureRunner"/>
		</classes>
	</test>
	
</suite>

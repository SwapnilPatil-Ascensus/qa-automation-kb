<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite verbose="1" name="Regression Test (Front Office) in Stage1 - Enrollments" parallel="tests" thread-count="1">
  <listeners>
    <listener class-name="com.cs529.qa.prime.core.PrimeResourceManager"/>
  </listeners>
  			
	<test name="AKB ABLE Enrollment Flow - Positive Cases">
		<parameter name="traunch" value="akb"></parameter>
		<parameter name="features" value="frontoffice/common/member/enrollment/feature/T100_NAA_EnrollmentPositive.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.ParallelFeatureRunner"/>
		</classes>
	</test>
	

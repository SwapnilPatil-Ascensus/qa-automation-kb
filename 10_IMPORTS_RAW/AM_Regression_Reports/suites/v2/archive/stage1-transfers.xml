<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite verbose="1" name="Regression Test (Front Office) in Stage1 - Transfers" parallel="tests" thread-count="1">

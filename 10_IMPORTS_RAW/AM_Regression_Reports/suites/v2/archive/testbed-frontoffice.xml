		</classes>
	</test>
	
	<test name="IAD Member Enrollment - Negative Test Cases">
		<parameter name="traunch" value="iad"></parameter>
		<parameter name="features" value="frontoffice/iad/member/enrollment/feature/IAD_EnrollmentNegative.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.ParallelFeatureRunner"/>
		</classes>
	</test>
	
	<test name="IAD Member Enrollment - Positive Test Cases">
		<parameter name="traunch" value="iad"></parameter>
		<parameter name="features" value="frontoffice/iad/member/enrollment/feature/IAD_EnrollmentPositive.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.ParallelFeatureRunner"/>
		</classes>
	</test>
						
			

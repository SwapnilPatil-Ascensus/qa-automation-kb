<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite verbose="2" name="Testbed (Front Office) Regression - Daily" parallel="tests" thread-count="1">
	<listeners>
		<listener class-name="com.cs529.qa.prime.core.PrimeResourceManager"/>
	</listeners>
	

	<test name="AKB Withdrawal - Positive Test Cases">
		<parameter name="traunch" value="akb"></parameter>
		<parameter name="features" value="frontoffice/akb/member/transactions/withdrawals/feature/MemberWithdrawal.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>

	
	<test name="MID Withdrawal - Positive Test Cases">
		<parameter name="traunch" value="mid"></parameter>
		<parameter name="features" value="frontoffice/mid/member/transactions/withdrawals/feature/MemberWithdrawal.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>
	
	<test name="MID Withdrawal - Negative Test Cases">
		<parameter name="traunch" value="mid"></parameter>
		<parameter name="features" value="frontoffice/mid/member/transactions/withdrawals/feature/MemberWithdrawalsNegative.feature"></parameter>	
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>
	
		
	<test name="NYD Member login Annual Exchange">

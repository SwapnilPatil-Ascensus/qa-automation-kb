		<parameter name="features" value="frontoffice/csr/member/transactions/withdrawal/feature/INDMODDistribution.feature"></parameter>	
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>
	
	<test name="WVD CSR Systematic Withdrawal Test Cases">
		<parameter name="traunch" value="wvd"></parameter>
		<parameter name="features" value="/frontoffice/csr/member/transactions/systematicwithdrawal/feature/SWPAutoNotation.feature"></parameter>
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>
				
</suite>

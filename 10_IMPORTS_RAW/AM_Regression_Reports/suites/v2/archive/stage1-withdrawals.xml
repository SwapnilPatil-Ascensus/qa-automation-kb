<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite verbose="1" name="Regression Test (Front Office) in Stage1 - Withdrawals" parallel="tests" thread-count="1">
  <listeners>
    <listener class-name="com.cs529.qa.prime.core.PrimeResourceManager"/>
  </listeners>
  		  
	<test name="NYD CSR-Member K12 Withdrawal Test Case">
		<parameter name="traunch" value="nyd"></parameter>
		<parameter name="features" value="/frontoffice/csr/member/transactions/withdrawal/feature/K12Distribution.feature"></parameter>	
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>
	
	<test name="NYD CSR-Member Qualified and Non-Qualified Withdrawal Test Case">
		<parameter name="traunch" value="nyd"></parameter>
		<parameter name="features" value="frontoffice/csr/member/transactions/withdrawal/feature/QandNQDistribution.feature"></parameter>	
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>

	<test name="TIAA MID CSR-Member Qualified and Non-Qualified Withdrawal Test Case">

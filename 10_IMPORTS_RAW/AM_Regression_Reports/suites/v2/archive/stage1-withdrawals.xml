		<parameter name="features" value="frontoffice/okd/csr/member/transactions/withdrawal/feature/QandNQDistribution.feature" />
		<classes>
			<class name="com.cs529.qa.prime.runner.FeatureRunner"/>
		</classes>
	</test>

	<test name="NYD  CSR-Withdrawal - Positive Test Cases">
		<parameter name="traunch" value="nyd"></parameter>
		<parameter name="features" value="frontoffice/csr/csr-greenscreen/transactions/withdrawal/feature/CSR_Distribution.feature"></parameter>	

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Regression Test (Front Office) in Stage1 - IDP Login" parallel="tests" thread-count="1" data-provider-thread-count="4">
    <listeners>
        <listener class-name="core.listener.PrimeResourceManager"/>
    </listeners>

    <!-- ============================================ -->
    <!-- POSITIVE TEST CASES - IDP Login Flows       -->
    <!-- ============================================ -->

    <!-- NMD IDP Login Flow -->
    <test name="NMD IDP Login Flow - Positive Cases">
        <parameter name="traunch" value="nmd"/>
        <parameter name="features" value="frontoffice/login/common/feature/IDPLogin.feature"/>
        <parameter name="tags" value="@regression and @dailyrun"/>
        <classes>
            <class name="core.runner.ParallelFeatureRunner"/>
        </classes>
    </test>

    <!-- New York Direct (NYD) - IDP Login Flow -->
    <test name="NYD IDP Login Flow - Positive Cases">
        <parameter name="traunch" value="nyd"/>
        <parameter name="features" value="frontoffice/login/common/feature/IDPLogin.feature"/>
        <parameter name="tags" value="@regression and @dailyrun"/>
        <classes>
            <class name="core.runner.ParallelFeatureRunner"/>
        </classes>
    </test>

    <!-- NJD IDP Login Flow -->
    <test name="NJD IDP Login Flow - Positive Cases">

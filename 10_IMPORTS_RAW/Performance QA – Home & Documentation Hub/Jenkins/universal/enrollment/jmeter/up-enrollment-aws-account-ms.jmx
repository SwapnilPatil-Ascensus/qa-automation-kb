            <hashTree/>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Header Generator" enabled="true">
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import javax.crypto.Mac;
import javax.crypto.spec.SecretKeySpec;
import org.apache.jmeter.protocol.http.control.Header;
import org.apache.jmeter.protocol.http.util.Base64Encoder;

TimeZone.setDefault(TimeZone.getTimeZone(&apos;UTC&apos;));

// Set the request id (x-request-id)
uuid = UUID.randomUUID().toString();
sampler.getHeaderManager().removeHeaderNamed(&quot;x-request-id&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-request-id&quot;, uuid));

// Set the current datetime (x-request-datetime)
currentUTC = new Date().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;);
sampler.getHeaderManager().removeHeaderNamed(&quot;x-request-datetime&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-request-datetime&quot;, currentUTC));

// Set the json signature (x-signature)
message = sampler.getArguments().getArgument(0).getValue();
Mac mac = Mac.getInstance(&quot;HmacSHA256&quot;);
SecretKeySpec secretKeySpec = new SecretKeySpec(vars.get(&quot;signing_key&quot;).decodeBase64(), &quot;HmacSHA256&quot;);
mac.init(secretKeySpec);
signature = mac.doFinal(message.getBytes()).encodeBase64().toString();
sampler.getHeaderManager().removeHeaderNamed(&quot;x-signature&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-signature&quot;, signature));

// Set x-request-action
var credentials = (vars.get(&quot;login&quot;) + &quot;:&quot; + vars.get(&quot;password&quot;)).getBytes().encodeBase64().toString();
sampler.getHeaderManager().removeHeaderNamed(&quot;x-request-action&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-request-action&quot;, &quot;snapshot &quot; + credentials));
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="snapshot (POST)" enabled="true">
              <stringProp name="TestPlan.comments">Take Snapshot</stringProp>
              <intProp name="HTTPSampler.concurrentPool">6</intProp>
              <stringProp name="HTTPSampler.domain">${host}</stringProp>
              <stringProp name="HTTPSampler.protocol">https</stringProp>
              <stringProp name="HTTPSampler.path">accounts/</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
              <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="" elementType="HTTPArgument">
                    <boolProp name="HTTPArgument.always_encode">false</boolProp>
                    <stringProp name="Argument.value">{&#xd;
  &quot;enrollMethod&quot;: &quot;W&quot;,&#xd;
  &quot;schema&quot;: &quot;urn:ascensus:529:1.0:enrollment&quot;,&#xd;
  &quot;urn:ascensus:529:1.0:enrollment&quot;: {&#xd;
    &quot;tcAcknowledgment&quot;: true,&#xd;
    &quot;user&quot;: {&#xd;
      &quot;gender&quot;: &quot;&quot;,&#xd;
      &quot;countryOfCitizenship&quot;: &quot;US&quot;,&#xd;
      &quot;questions&quot;: {&#xd;
        &quot;enrollInUpromise&quot;: false,&#xd;
        &quot;howYouHeardUs&quot;: &quot;&quot;,&#xd;
        &quot;isMailingAddrDiff&quot;: false&#xd;
      },&#xd;
      &quot;id&quot;: &quot;${userUuid}&quot;,&#xd;
      &quot;name&quot;: {&#xd;
        &quot;first&quot;: &quot;${userFirst}&quot;,&#xd;
        &quot;last&quot;: &quot;${userLast}&quot;&#xd;
      },&#xd;
      &quot;contact&quot;: {&#xd;
        &quot;email&quot;: &quot;${userEmail}&quot;,&#xd;
        &quot;daytimePhone&quot;: &quot;${userWPhone}&quot;,&#xd;
        &quot;daytimePhoneType&quot;: &quot;C&quot;,&#xd;
        &quot;eveningPhone&quot;: &quot;${userHPhone}&quot;,&#xd;
        &quot;eveningPhoneType&quot;: &quot;C&quot;&#xd;
      },&#xd;
      &quot;citizenOrGCholder&quot;: true,&#xd;
      &quot;ssn&quot;: &quot;${userSsn}&quot;,&#xd;
      &quot;dob&quot;: &quot;${userDob}&quot;,&#xd;
      &quot;login&quot;: {&#xd;
        &quot;username&quot;: &quot;${login}&quot;,&#xd;
        &quot;password&quot;: &quot;${password}&quot;,&#xd;
        &quot;securityPassPhrase&quot;: null,&#xd;
        &quot;securityChallenges&quot;: null&#xd;
      },&#xd;
      &quot;addresses&quot;: [&#xd;
        {&#xd;
          &quot;addressType&quot;: &quot;8&quot;,&#xd;
          &quot;streetAddress1&quot;: &quot;${userPAdd1}&quot;,&#xd;
          &quot;streetAddress2&quot;: &quot;${userPAdd2}&quot;,&#xd;
          &quot;city&quot;: &quot;Aberdeen&quot;,&#xd;
          &quot;zipCode&quot;: &quot;21001&quot;,&#xd;
          &quot;state&quot;: &quot;MD&quot;,&#xd;
          &quot;country&quot;: &quot;US&quot;&#xd;
        },&#xd;
        {&#xd;
          &quot;addressType&quot;: &quot;4&quot;,&#xd;
          &quot;streetAddress1&quot;: &quot;${userMAdd1}&quot;,&#xd;
          &quot;streetAddress2&quot;: &quot;${userMAdd2}&quot;,&#xd;
          &quot;city&quot;: &quot;Newton&quot;,&#xd;
          &quot;zipCode&quot;: &quot;02459&quot;,&#xd;
          &quot;state&quot;: &quot;MA&quot;,&#xd;
          &quot;country&quot;: &quot;US&quot;&#xd;
        }&#xd;
      ]&#xd;
    },&#xd;
    &quot;metadata&quot;: {&#xd;
      &quot;autoSelectFeature&quot;: false,&#xd;
      &quot;deliveryMethodAgreement&quot;: true,&#xd;
      &quot;initialFundings&quot;: [&#xd;
        {&#xd;
          &quot;beneId&quot;: &quot;${beneUuid}&quot;,&#xd;
          &quot;fundingId&quot;: &quot;${fundingUuid1}&quot;&#xd;
        }&#xd;
      ],&#xd;
      &quot;recurringFundings&quot;: [&#xd;
        {&#xd;
          &quot;beneId&quot;: &quot;${beneUuid}&quot;,&#xd;
          &quot;fundingId&quot;: &quot;${fundingUuid2}&quot;&#xd;
        }&#xd;
      ]&#xd;
    },&#xd;
    &quot;beneficiaries&quot;: [&#xd;
      {&#xd;
        &quot;id&quot;: &quot;${beneUuid}&quot;,&#xd;
        &quot;relationship&quot;: &quot;Child&quot;,&#xd;
        &quot;name&quot;: {&#xd;
          &quot;first&quot;: &quot;${beneFirst}&quot;,&#xd;
          &quot;last&quot;: &quot;${beneLast}&quot;&#xd;
        },&#xd;
        &quot;ssn&quot;: &quot;${beneSsn}&quot;,&#xd;
        &quot;dob&quot;: &quot;${beneDob}&quot;,&#xd;
        &quot;citizenOrGCholder&quot;: true,&#xd;
        &quot;addresses&quot;: [&#xd;

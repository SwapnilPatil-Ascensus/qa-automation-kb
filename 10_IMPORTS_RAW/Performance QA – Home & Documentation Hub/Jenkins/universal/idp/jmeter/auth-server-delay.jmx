          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate JWT Token" enabled="true">
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import io.jsonwebtoken.JwtBuilder;
import io.jsonwebtoken.Jwts;
import java.security.KeyFactory;
import java.security.spec.PKCS8EncodedKeySpec;
import java.security.interfaces.RSAPrivateKey;
import java.util.Base64;

byte[] encoded = Base64.getDecoder().decode(vars.get(&quot;privateKey&quot;));
KeyFactory kf = KeyFactory.getInstance(&quot;RSA&quot;);
PKCS8EncodedKeySpec keySpec = new PKCS8EncodedKeySpec(encoded);
RSAPrivateKey rsa = (RSAPrivateKey) kf.generatePrivate(keySpec);

//Create JWT token
JwtBuilder builder = Jwts.builder().claims()
      .issuer(vars.get(&quot;privateId&quot;))
      .subject(vars.get(&quot;privateId&quot;))
      .expiration(new Date(System.currentTimeMillis() + (86400 * 1000)))
      .and()
      .signWith(rsa)
      .audience().add(&quot;https://&quot; + vars.get(&quot;authentication&quot;) + &quot;/services/oauth2&quot;)
      .and();

vars.put(&quot;bearerToken&quot;, builder.compact());
</stringProp>

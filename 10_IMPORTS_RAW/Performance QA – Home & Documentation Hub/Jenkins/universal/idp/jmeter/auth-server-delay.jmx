currentUTC = new Date().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;);
sampler.getHeaderManager().removeHeaderNamed(&quot;x-request-datetime&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-request-datetime&quot;, currentUTC));
</stringProp>

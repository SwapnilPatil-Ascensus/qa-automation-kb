          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Decrypt Credentials">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import javax.crypto.Cipher;
import javax.crypto.SecretKey;
import javax.crypto.spec.IvParameterSpec;
import java.util.Base64;

// Decrypt data
def decrypt(SecretKey key, String encryptedData) {
    Cipher cipher = Cipher.getInstance(&quot;AES/CBC/PKCS5Padding&quot;);
    byte[] iv = new byte[16]; // Initialization vector (16 bytes)
    IvParameterSpec ivSpec = new IvParameterSpec(iv);
    cipher.init(Cipher.DECRYPT_MODE, key, ivSpec);
    byte[] decodedData = Base64.decoder.decode(encryptedData);
    byte[] decryptedData = cipher.doFinal(decodedData);
    return new String(decryptedData, &quot;UTF-8&quot;);
}

// Expect to decrypt credentials
if (vars.get(&quot;encryption&quot;) == &apos;true&apos;) {

	// Get loaded key
	SecretKey key = vars.getObject(&quot;loadedKey&quot;);
		
	// Decrypt portal username
	String encryptedUsername = vars.get(&quot;userUsernameEncrypt&quot;)
	String decryptedUsername = decrypt(key, encryptedUsername)
	vars.put(&quot;userUsername&quot;, decryptedUsername)
	//log.info(&quot;decryptedUsername: &quot; + decryptedUsername)
	
	// Decrypt portal password
	String encryptedPassword = vars.get(&quot;userPasswordEncrypt&quot;)
	String decryptedPassword = decrypt(key, encryptedPassword)
	String credentials = decryptedPassword.getBytes().encodeBase64().toString();
	vars.put(&quot;userPassword&quot;, credentials)
	//log.info(&quot;decryptedPassword: &quot; + decryptedPassword)
}

// Do not decrypt credentials
else {
	vars.put(&quot;userUsername&quot;, vars.get(&quot;userUsernameEncrypt&quot;))
	String pass = vars.get(&quot;userPasswordEncrypt&quot;).getBytes().encodeBase64().toString();
	vars.put(&quot;userPassword&quot;, pass)
}

</stringProp>
          </JSR223Sampler>

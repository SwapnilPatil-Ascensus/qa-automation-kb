        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Create Challenge + Verifier" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.security.SecureRandom;
import java.util.Base64;
import java.security.MessageDigest;

SecureRandom sr = new SecureRandom();
byte[] code = new byte[32];
sr.nextBytes(code);
String verifier = Base64.getUrlEncoder().withoutPadding().encodeToString(code);
vars.put(&quot;verifier&quot;, verifier);

MessageDigest mdb = MessageDigest.getInstance(&quot;SHA-256&quot;);
byte[] encValue = mdb.digest(verifier.getBytes());
String challenge = Base64.getUrlEncoder().withoutPadding().encodeToString(encValue);
vars.put(&quot;challenge&quot;, challenge);
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Output Challenge + Verifier" enabled="false">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">log.info(&quot;CHALLENGE: &quot; + vars.get(&quot;challenge&quot;));
log.info(&quot;VERIFIER: &quot;  + vars.get(&quot;verifier&quot;));</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Create X-REQUEST-DATETIME / Sardine Key" enabled="true">
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">TimeZone.setDefault(TimeZone.getTimeZone(&apos;UTC&apos;));
Random random = new Random();

// Set the current datetime (x-request-datetime)
currentUTC = new Date().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;);
vars.put(&quot;datetime&quot;, currentUTC);

////////////////////////////// SARDINE //////////////////////////////////////////////////

vars.put(&quot;sardinekey&quot;, UUID.randomUUID().toString());
//log.info(&quot;Sardine Key: &quot; + vars.get(&quot;sardinekey&quot;))
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>

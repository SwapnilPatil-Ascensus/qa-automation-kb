        ac.date_closed cl_date_closed,
        tactc.seq_code_id tactc_seq_code_id,
        tactc.type tactc_type,
        tactc.description tactc_description,
        tactc.code_id tactc_code_id,
        tac.freeze_date tac_freeze_date,
        tac.csr_id tac_csr_id,
        tac.note tac_note,
        tmctc.seq_code_id tmctc_seq_code_id,
        tmctc.type tmctc_type,
        tmctc.description tmctc_description,
        tmctc.code_id tmctc_code_id,
        tmc.ctl_upd_dttm tmc_ctl_upd_dttm,
        tmc.csr_id tmc_csr_id,
        tmc.note tmc_note,
        emp.employer_name emp_employer_name,
        rel.FUND_SUB_CLASS_TYPE emp_fund_sub_classtype
        from tu_acct a,
        tu_person p,
        tu_bene b,
        tu_successor s,
        tu_traunch t,
        tu_member m,
        tu_codes tc,
        tu_person secp,
        tu_avatar_image ai,
        tu_acct_closed ac,
        tu_closed_reason cl,
        tu_converted_acct ca,
        tu_acct_constraint tac,
        tu_codes tactc,
        tu_member_constraint tmc,
        tu_codes tmctc,
        tu_member_employer me,
        tu_employer emp,
        TU_EMPLOYER_REP_REL rel
        where a.seq_part_id = p.seq_person_id
        and a.seq_bene_id = b.seq_bene_id
        and a.seq_sx_id = s.seq_sx_id
        and a.traunch_id = t.traunch_id
        and a.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos; 
        and a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
        and m.uii_member_id = a.uii_member_id
        and m.client_segment_code = tc.seq_code_id(+)
        and t.ctl_rec_stat = &apos;A&apos;
        and a.seq_sec_owner_id = secp.seq_person_id(+)
        and a.seq_avatar_image_id = ai.seq_avatar_image_id(+)
        and a.seq_acct_id = ac.seq_acct_id(+)
        and ac.seq_closed_reason_id = cl.seq_closed_reason_id(+)
        and a.seq_acct_id = ca.seq_acct_id(+)
        and a.seq_acct_id = tac.seq_acct_id(+)
        and tac.seq_code_id = tactc.seq_code_id(+)
        and nvl(tac.ctl_rec_stat(+), &apos;A&apos;) != &apos;X&apos;
        and upper(tactc.description(+)) not like &apos;%NONE%&apos;
        and a.uii_member_id = tmc.uii_member_id(+)
        and tmc.seq_code_id = tmctc.seq_code_id(+)
        and nvl(tmc.ctl_rec_stat(+), &apos;A&apos;) != &apos;X&apos;
        and tmctc.type(+) = &apos;RESTR&apos;
        and UPPER(tmctc.description(+)) not like &apos;%NONE%&apos;
        and me.uii_member_id (+)= m.uii_member_id
        and emp.seq_employer_id (+)= me.seq_employer_id
        and rel.seq_employer_id (+)= emp.seq_employer_id
        and nvl(me.ctl_rec_stat(+), &apos;A&apos;) != &apos;X&apos;</stringProp>

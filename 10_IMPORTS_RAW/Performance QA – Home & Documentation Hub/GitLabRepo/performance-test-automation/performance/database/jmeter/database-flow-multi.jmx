        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getCountFraudBlockByEmail" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">		SELECT
			COUNT(*) cnt
		FROM 
			TU_FRAUD_BLOCK_INFO
		WHERE
			CTL_REC_STAT IN (&apos;A&apos;,&apos;R&apos;)
			AND ((TEMP_BLOCK_FLAG = &apos;Y&apos; and TEMP_BLOCK_ENDTIME &gt; sysdate) OR PERMANENT_FLAG = &apos;Y&apos;)
			AND UPPER(EMAIL) = UPPER(&apos;${__V(EMAIL_1)}&apos;  )</stringProp>

          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getPaLoiByRoaNumber" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select l.SEQ_LOI_ID &quot;seqLoiId&quot;, l.SEQ_ACCT_ID &quot;seqAcctId&quot;, a.uii_acct_id||a.uii_acct_ext &quot;uiiAcctId&quot;, l.AGREEMENT_AMOUNT &quot;aggreementAmount&quot;,
        l.EFFECTIVE_DATE &quot;effectiveDate&quot;, l.EXPIRATION_DATE &quot;expirationDate&quot;, l.PRIOR_CREDIT_AMOUNT &quot;priorCreditAmount&quot;,
        l.RETROACTIVE_DISCOUNT_DATE &quot;retroactiveDiscountDate&quot;, l.LOI_NUMBER_AT_PA &quot;loiNumberAtPa&quot;, l.FILING_DATE &quot;filingDate&quot;,
        l.ACCRUED_PURCHASED_AMOUNT &quot;accruedPurchaseAmount&quot;, l.REMAINING_PURCHASE_AMOUNT &quot;remainingPurchaseAmout&quot;, l.ESCROW_AMOUNT &quot;escrowAmout&quot;,
        l.CURRENT_MARKET_VALUE &quot;currentMarketValue&quot;, l.UNFULFILLED_LOI_CONFIRM_DATE &quot;unfulfilledLoiConfirmDate&quot;,
        cd.SEQ_CODE_ID &quot;status.seqCodeId&quot;, cd.CODE_ID &quot;status.codeId&quot;, cd.DESCRIPTION &quot;status.desc&quot;, cd.TYPE &quot;status.type&quot;,
        l.CSR_ID &quot;csrId&quot;, l.CHANGE_ID &quot;changeId&quot;, l.sync_state &quot;syncState&quot;
        from tu_loi l, tu_acct a, tu_member m, tu_codes cd, TU_BREAKPOINT_PARTNER_GROUP bpg
        where l.seq_acct_id = a.seq_acct_id
        and m.uii_member_id = a.uii_member_id
        and m.roa_id = &apos;${__V(ROA_ID_1)}&apos;
        and l.status = cd.seq_code_id
        and cd.code_id = &apos;1&apos;
        and l.ctl_rec_stat = &apos;A&apos;
        and a.TRAUNCH_ID = bpg.TRAUNCH_ID
        and bpg.ctl_rec_stat = &apos;A&apos;
        and bpg.PARTNER_ID = &apos;${__V(PARTNER_ID_1)}&apos;</stringProp>

        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAllMemberEmployers" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        SELECT
          me.seq_employer_id,
          me.ctl_ins_dttm,
          me.ctl_upd_dttm ,
          me.ctl_upd_user,
          me.ctl_rec_stat,
          me.seq_dept_id,
          me.employee_id,          
          et.traunch_id,
          et.employer_code,
          e.employer_name,
          et.inception_date,
          et.termination_date,
          et.ctl_rec_stat,
          e.payroll_deduction,
          e.aip_deduction,
          et.employer_program_eligible
        FROM
          	tu_acct a,
  			tu_member_employer me,
  			tu_employer e,
  			tu_employer_traunch et
        WHERE
            e.seq_employer_id = et.seq_employer_id
		AND me.uii_member_id    = &apos;${__V(APP_MEMBER_ID_1)}&apos;
		AND a.uii_member_id     = me.uii_member_id
		AND a.traunch_id        = et.traunch_id
		AND me.ctl_rec_stat     = &apos;A&apos;
		AND et.ctl_rec_stat     = &apos;A&apos;
		AND e.seq_employer_id   = me.seq_employer_id
		AND rownum              = 1
          ORDER BY me.ctl_upd_dttm DESC, me.ctl_rec_stat ASC</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">CNT</stringProp>

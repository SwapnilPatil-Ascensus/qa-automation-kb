        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAuthenticationByLoginId" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        select
            distinct ac.app_member_id,
            ac.application_id,
            ac.active,
            ln.login_id,
            ln.username,
            m.email,
            ln.e_pwd,
            ln.pwd_ci,
            ln.username,
            ln.e_challenge,
            ln.challenge_ci,
            ln.e_response,
            ln.response_ci,
            ln.e_challenge1,
            ln.challenge1_ci,
            ln.e_response1,
            ln.response1_ci,
            ln.e_challenge2,
            ln.challenge2_ci,
            ln.e_response2,
            ln.response2_ci,
            ln.e_logon_img,
            ln.logon_img_ci,
            ln.e_pass_phrase,
            ln.pass_phrase_ci,
            ln.lock_count,
            ln.challenge_lock_count,
            ln.one_time_pwd,
            m.email_soft_fail,
            m.email_hard_fail,
            t.branding,
            p.first_name||&apos; &apos;||p.last_name &quot;fullName&quot;,
            a.uii_acct_id,
            m.web_access,
            ln.pwd_bit,
            m.schwab_sso_status,
            ln.saml2_partner_id
        from
            ta_app_context ac,
            ta_login ln,
            tu_member m,
            tu_traunch t,
            tu_acct a,
            tu_person p
        where
            ln.login_id = &apos;${__V(LOGIN_ID_1)}&apos;
            and ac.application_id = &apos;uii&apos;
            and ac.app_member_id = m.uii_member_id
            and ln.login_id = ac.login_id
            and t.traunch_id = ln.traunch_id
            and a.uii_member_id = m.uii_member_id
            and a.seq_part_id = p.seq_person_id</stringProp>

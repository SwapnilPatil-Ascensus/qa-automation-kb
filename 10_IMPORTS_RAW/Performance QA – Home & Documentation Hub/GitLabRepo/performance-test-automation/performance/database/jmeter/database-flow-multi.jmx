            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select
        tma.seq_acct_id, tma.seq_matching_acct_id, tma.seq_matching_program_id, tma.matching_amount,
        tma.ctl_ins_dttm, tma.ctl_upd_dttm, tma.ctl_upd_user, tma.ctl_rec_stat, tmp.program_type,
        macct.uii_acct_id matching_uii_acct_id, macct.uii_acct_ext matching_uii_acct_ext,
        tma.eligibility_year, tma.income_level_code_id, tma.mg_multi_yr_match, tma.scan_date, tma.income_lvl_free_txt,

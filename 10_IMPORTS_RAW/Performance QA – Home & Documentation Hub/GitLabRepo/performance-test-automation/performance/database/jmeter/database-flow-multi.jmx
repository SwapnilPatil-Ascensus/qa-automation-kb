          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getDealerNavTxnTypeListByDealerId" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select txn_type||&apos;,&apos;||c.DESCRIPTION ||&apos;,&apos;||c.SEQ_CODE_ID as &quot;txnType&quot;
        from tu_nav_dealer nd, tu_codes c
        where
        c.SEQ_CODE_ID(+) = nd.NAV_TYPE
        and nd.seq_dealer_id = &apos;${__V(SEQ_DEALER_ID_${count})}&apos;
        and nd.traunch_id = &apos;${__V(A_TRAUNCH_ID_${count})}&apos;
        and nd.ctl_rec_stat = &apos;A&apos;</stringProp>

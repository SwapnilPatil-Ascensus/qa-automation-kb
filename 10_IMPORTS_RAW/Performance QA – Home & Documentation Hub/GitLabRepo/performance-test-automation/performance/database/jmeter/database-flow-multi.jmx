          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAccountProgramAndSponsor" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        SELECT distinct
        	b.PROGRAM_NAME &quot;name&quot;, 
        	s.SPONSOR_NAME &quot;sponsor.name&quot;,
        	s.boost_num &quot;sponsor.boostNum&quot;
        FROM 
	        TU_BOOST_RECIPIENT br,
			TU_BOOST_RECIPIENT_PROGRAM rp,
			TU_BOOST_PROGRAM b,
			TU_BOOST_SPONSOR s
		WHERE 
			br.SEQ_BOOST_RECIPIENT_ID = rp.SEQ_BOOST_RECIPIENT_ID
			AND rp.SEQ_BOOST_PROGRAM_ID = b.SEQ_BOOST_PROGRAM_ID
			AND b.SEQ_BOOST_SPONSOR_ID = s.SEQ_BOOST_SPONSOR_ID
			and s.CTL_REC_STAT = &apos;A&apos;
			and b.CTL_REC_STAT = &apos;A&apos;
			and br.CTL_REC_STAT = &apos;A&apos;
			and rp.CTL_REC_STAT = &apos;A&apos;
			AND br.SEQ_ACCT_ID = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;</stringProp>

          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAccountAllocationPercentages" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select al.fund_id, al.percent_alloc, al.ctl_ins_dttm, al.ctl_upd_dttm, al.sync_state,
            al.realloc_date, al.change_id, al.elec_type, al.ctl_upd_dttm, al.sync_state,
            al.realloc_date, al.change_id, al.elec_type, f.fund_name, f.fund_desc,
            f.omni_fund_id, f.class_type, f.class_sub_type, f.classification, f.fund_type , f.class_sub_type,
            nvl(fw.price,0.0) price, f.display_order, f.allows_new_investment, f.cusip
        from tu_acct_alloc al, tu_funds f, tu_acct a, tu_fund_price_web fw
        where al.seq_acct_id=a.seq_acct_id
            and a.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
            and a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
            and  al.fund_id=f.fund_id
            and f.fund_id = fw.fund_id(+) </stringProp>

        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getMemberBank" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">Select distinct b.seq_bnk_id, b.NAME, b.BANK_NICK_NAME, b.ROUTING_NUM, b.ACCT_NUM, b.ACCT_TYPE, b.STATUS, nvl(b.CTL_INS_DTTM,to_date(&apos;1970-01-01 00:00&apos;, &apos;YYYY-MM-DD HH24:MI&apos;)) CREATE_DATE,b.CTL_UPD_DTTM MODIFIED_DATE, b.CHANGE_ID, b.BANK_PHONE, b.IS_DOMESTIC,b.PRI_OWNER_FIRST_NAME,b.PRI_OWNER_MIDDLE_INITIAL,b.PRI_OWNER_LAST_NAME,b.SEC_OWNER_FIRST_NAME,b.SEC_OWNER_MIDDLE_INITIAL,b.SEC_OWNER_LAST_NAME,b.WITHDRAWAL_ELIGIBLE, b.VERIFICATION_STATUS from TU_BANK b where b.status != &apos;X&apos; and b.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;  order by b.NAME</stringProp>

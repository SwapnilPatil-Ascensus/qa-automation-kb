          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: retrieveHistoryEntriesJoinedWithAccount (DST)" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">   SELECT ty.SEQ_DST_TXN_TYPE_ID,
    ty.UII_REVERSE,
    ty.UII_TRAN_CODE,
    ty.UII_TRAN_SUB_CODE,
    ty.DISPLAY_HIST,
    ty.CHANGE_FACTOR,
    txndesc.DESCRIPTION,
    txndesc.DISPLAY_ORDER,
    txn.TRADE_DATE,
    txn.RUN_DATE,
    txn.REV_DATE,
    sum(txn.SHARES) AS SHARES,
    txn.PRICE,
    sum(txn.AMOUNT) AS AMT,
    sum(txn.PRINCIPAL) AS PRINCIPAL,
    sum(txn.DLR_COM_AMT) AS DLR_COM_AMT,
    sum(txn.DIST_COM_AMT) AS DIST_COM_AMT,
    txn.ADV_COM_AMT,
    txn.SALES_CHARGE,
    txn.GROSS_NET_IND,
    txn.CONTRIB_YEAR,
    txn.SEQ_FIN_TXN_ID,
    txn.SEQ_DST_ACCT_TXN_ID,
    txn.NSCC_ORDER_NUM,
    txn.FUND_ID,
    txn.SEQ_ACCT_ID,
    txn.DEALER_ID,
    txn.BRANCH_ID,
    txn.REP_ID,
    fund.OMNI_FUND_ID,
    txn.CHANGE_ID,
    tr.BRANDING,
    c.PAYEE_NAME,
    (select description from tu_codes where type = &apos;DISB_TYPE&apos; and seq_code_id = disb.DISB_TYPE) DISB_TYPE,
    disb.SEQ_DISBURSEMENT_ID,
	(select &apos;Y&apos; from tdst_partner_rept_txn_types pt
	where pt.report_name = &apos;HLD Compensation&apos;
	and pt.partner = &apos;Hartford Life&apos;
	and pt.uii_tran_code = ty.uii_tran_code
	and pt.uii_tran_sub_code = ty.uii_tran_sub_code
	and ctl_rec_stat = &apos;A&apos;) as hldComp,
	txn.from_to_seq_acct_id,
	txn.AS_OF_RES_CODE,
	txn.DISCOUNT_CATEGORY_CODE,
	txn.dst_acct_num
    FROM tdst_acct_txn txn,
    tdst_txn_type ty,
    tdst_traunch_txn_type txndesc,
    tu_acct acct,
    tu_funds fund,
    tu_traunch tr,
    tu_disbursement disb,
    tu_disbursement_check dc,
    tu_check c
    WHERE txn.seq_dst_txn_type_id = ty.seq_dst_txn_type_id
    AND txndesc.seq_dst_txn_type_id = ty.seq_dst_txn_type_id
    AND txndesc.traunch_id = acct.traunch_id
    AND txn.seq_acct_id = acct.seq_acct_id
    AND txn.fund_id = fund.fund_id
    AND ty.DISPLAY_HIST = &apos;Y&apos;
    AND acct.traunch_id = tr.traunch_id
    AND txn.SEQ_FIN_TXN_ID = disb.SEQ_FIN_TXN_ID(+)
    AND disb.SEQ_DISBURSEMENT_ID = dc.SEQ_DISBURSEMENT_ID(+)
    AND dc.SEQ_CHECK_ID = c.SEQ_CHECK_ID(+)
     --SQL Name:DstHistory/dst/retrieveHistoryEntriesJoinedWithAccount/byAcctIdAndFromDate&lt;SQL_KEY_END&gt;

        and acct.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
        and acct.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
        and txn.run_date &gt;= trunc(to_date(&apos;10/27/2023&apos;, &apos;MM/DD/YYYY&apos;))
          
     --SQL Name:DstHistory/dst/retrieveHistoryEntriesJoinedWithAccount/groupBy&lt;SQL_KEY_END&gt;

        GROUP BY ty.SEQ_DST_TXN_TYPE_ID,
        ty.UII_REVERSE,
        ty.UII_TRAN_CODE,
        ty.UII_TRAN_SUB_CODE,
        ty.DISPLAY_HIST,
        ty.CHANGE_FACTOR,
        txndesc.DESCRIPTION,
        txndesc.DISPLAY_ORDER,
        txn.TRADE_DATE,
        txn.RUN_DATE,
        txn.REV_DATE,
        txn.PRICE,
        txn.ADV_COM_AMT,
        txn.SALES_CHARGE,
        txn.GROSS_NET_IND,
        txn.CONTRIB_YEAR,
        txn.SEQ_FIN_TXN_ID,
        txn.SEQ_DST_ACCT_TXN_ID,
        txn.NSCC_ORDER_NUM,
        txn.FUND_ID,
        txn.SEQ_ACCT_ID,
        txn.DEALER_ID,
        txn.BRANCH_ID,
        txn.REP_ID,
        fund.OMNI_FUND_ID,
        txn.CHANGE_ID,
        tr.BRANDING,
        c.PAYEE_NAME,
        disb.DISB_TYPE,
        disb.SEQ_DISBURSEMENT_ID,
        txn.from_to_seq_acct_id,
        txn.AS_OF_RES_CODE,
        txn.DISCOUNT_CATEGORY_CODE,
        txn.dst_acct_num
     --SQL Name:DstHistory/dst/retrieveHistoryEntriesJoinedWithAccount/byAcctIdAndFromDate/orderBy&lt;SQL_KEY_END&gt;

       ORDER BY  txn.RUN_DATE desc, txn.TRADE_DATE desc, txndesc.DISPLAY_ORDER, txn.SEQ_FIN_TXN_ID desc, ty.UII_TRAN_CODE asc</stringProp>

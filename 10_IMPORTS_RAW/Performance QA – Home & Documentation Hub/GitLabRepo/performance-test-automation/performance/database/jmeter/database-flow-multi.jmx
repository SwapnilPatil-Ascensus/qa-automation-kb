          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: retrieveHistoryEntriesJoinedWithAccount (Envision)" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select
            txn.seq_env_acct_txn_id, ty.seq_env_txn_type_id, ty.uii_reverse, ty.env_tran_code, txndesc.display_hist,
            txn.change_factor, txndesc.description, txndesc.display_order, txn.trade_date, txn.run_date, txn.rev_date,
            txn.shares, txn.price, txn.net_amount, txn.gross_amount, txn.principal, txn.total_comm_amount,
            txn.dealer_comm_amount, txn.sales_charge_amount, txn.advance_comm_amount, txn.underwriter_comm_amount,
            txn.total_comm_rate, txn.dealer_comm_rate, txn.sales_charge_rate, txn.gross_net_ind, txn.contrib_year,
            txn.seq_fin_txn_id, txn.nscc_control_number, txn.fund_id, txn.traunch_id, txn.seq_acct_id, txn.dealer_number,
            txn.branch_number, txn.rep_number, txn.bin, fund.omni_fund_id, txn.change_id, tr.branding, c.payee_name,
            (select description from tu_codes where type = &apos;DISB_TYPE&apos; and seq_code_id = disb.disb_type) disb_type,
            disb.seq_disbursement_id, txn.from_to_seq_acct_id, txn.as_of_reason_code, txn.voucher_number, txn.cdsc_amount,
            txn.cdsc_waiver_reason_code, fts.seq_fin_type_source_id, fts.fin_type_category as &quot;fts_fin_type_category&quot;,
            fts.fin_type as &quot;fts_fin_type&quot;, fts.source_code as &quot;fts_source_code&quot;, fts.description as &quot;fts_description&quot;,
            fts.ctl_rec_stat as &quot;fts_ctl_rec_stat&quot;, txndesc.change_type_category, paw.PAYMENT_REFERENCE_ID as &quot;paymentReferenceId&quot;,
            paw.PAYEE_FIRSTNAME as &quot;payeeFirstName&quot;, paw.PAYEE_LASTNAME as &quot;payeeLastName&quot;, paw.PAYEE_ID as &quot;payeeId&quot;,
            paw.PAYMENT_STATUS as &quot;paymentStatus&quot;, smd.SCHOOL_NAME as &quot;schoolName&quot;, paw.CTL_REC_STAT as &quot;pawCtlRecStat&quot;
        from
            tenv_acct_txn txn,
            tenv_txn_type ty,
            tenv_traunch_txn_type txndesc,
            tu_fin_type_source fts,
            tu_acct acct,
            tu_funds fund,
            tu_traunch tr,
            tu_disbursement disb,
            tu_disbursement_check dc,
            tu_check c,
            TU_ACH_PARTNER_WD paw,
            TU_SCHOOL_METADATA smd
        where
            txn.seq_env_txn_type_id = ty.seq_env_txn_type_id
            and txndesc.seq_env_txn_type_id = ty.seq_env_txn_type_id
            and ty.seq_fin_type_source_id = fts.seq_fin_type_source_id
            and txndesc.traunch_id = acct.traunch_id
            and txn.traunch_id = acct.traunch_id
            and txn.seq_acct_id = acct.seq_acct_id
            and txn.fund_id = fund.fund_id
            and txndesc.display_hist = &apos;Y&apos;
            and acct.traunch_id = tr.traunch_id
            and txn.seq_fin_txn_id = disb.seq_fin_txn_id(+)
            and disb.seq_disbursement_id = dc.seq_disbursement_id(+)
            and dc.seq_check_id = c.seq_check_id(+)		    
            and txn.SEQ_FIN_TXN_ID           = paw.SEQ_FIN_TXN_ID(+)
            and paw.SEQ_SCHOOL_ID            = smd.SEQ_SCHOOL_ID(+)
     --SQL Name:envision/byAcctIdAndFromDate&lt;SQL_KEY_END&gt;

        and acct.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
        and acct.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
        and txn.run_date &gt;= trunc(to_date(&apos;10/27/2023&apos;, &apos;MM/DD/YYYY&apos;))
     --SQL Name:envision/orderByTradeDateRunDate&lt;SQL_KEY_END&gt;

        order by
            txn.RUN_DATE desc,
            txn.TRADE_DATE desc,
            txndesc.DISPLAY_ORDER,
            txn.SEQ_FIN_TXN_ID desc,
            txn.ENV_TXN_ID,
            txn.ENV_TXN_LINE_NUM desc,
            txn.seq_env_acct_txn_id desc,
            ty.env_tran_code asc</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">SEQ_REP_ID</stringProp>
          </JDBCSampler>
          <hashTree>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Response Assertion - Status" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="49586">200</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message"></stringProp>
              <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">1</intProp>
            </ResponseAssertion>
            <hashTree/>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Response Assertion - Count" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="53">5</stringProp>
              </collectionProp>

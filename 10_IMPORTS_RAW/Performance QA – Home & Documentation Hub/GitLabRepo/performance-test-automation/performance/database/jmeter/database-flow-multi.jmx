          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getMonthEndBalanceByAccount" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select
            sb.rm &quot;rmDate&quot;,
            SUM(ROUND(sb.UNITS * fp.PRICE, 2)) &quot;balance&quot;
        from
            TU_STMT_BAL sb, tu_fund_price fp
        where
            sb.SEQ_ACCT_ID = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
            and sb.FUND_ID = fp.FUND_ID
            and fp.PRICE_DATE =  (
                select
                    max(fp1.price_date)
                from
                   tu_fund_price fp1
                where
                    to_char(fp1.PRICE_DATE, &apos;YYYYMM&apos;) = sb.rm
                    and fp1.fund_id = sb.FUND_ID
                    and fp1.PRICE_DATE &gt;= add_months(trunc(sysdate), -18)
                group by fp1.fund_id
            )
            and sb.rm &gt;= to_char(add_months(trunc(sysdate), -18), &apos;YYYYMM&apos;)
        group by sb.rm
        order by sb.rm asc</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>

          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getYearlyContribs (Envision)" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">	    select
	        a.traunch_id, a.uii_acct_id, a.uii_acct_ext, o.contrib_year as tax_year,
            sum(o.gross_amount * o.change_factor) as value
        from
            tenv_acct_txn o, tenv_txn_type t, tenv_traunch_txn_type tt, tu_acct a
        where
            o.seq_acct_id = a.seq_acct_id
            and a.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
            and a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
            and o.contrib_year &gt;= &apos;2023&apos;
            and o.seq_env_txn_type_id = t.seq_env_txn_type_id
            and t.seq_env_txn_type_id = tt.seq_env_txn_type_id
            and tt.traunch_id = o.traunch_id
            and tt.traunch_id = a.traunch_id
            and tt.display_hist = &apos;Y&apos;
            and tt.txn_type = &apos;CONTRIBUTION&apos;
        group by
            a.traunch_id, a.uii_acct_id, a.uii_acct_ext, o.contrib_year</stringProp>

from tu_acct a,
 tu_person p,
 tu_bene b,
 tu_successor s,
 tu_traunch t,
 tu_member m,
 tu_codes tc,
tu_codes bene,
 tu_member_employer me,
 tu_employer emp,
 TU_EMPLOYER_REP_REL rel,
 tu_codes class_eligibility_code,
 tu_codes language_codes  
 where a.seq_part_id = p.seq_person_id 
and a.seq_bene_id=b.seq_bene_id 
and a.seq_sx_id=s.seq_sx_id 
and a.traunch_id = t.traunch_id 
and a.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
and a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
and m.uii_member_id = a.uii_member_id 
and m.client_segment_code = tc.seq_code_id(+) 
and me.uii_member_id (+) = m.uii_member_id 
and emp.seq_employer_id (+) = me.seq_employer_id 
and rel.seq_employer_id (+) = emp.seq_employer_id 
and nvl(me.ctl_rec_stat(+), &apos;A&apos;) != &apos;X&apos; 
and a.CLASS_ELIGIBILITY_FLAG = class_eligibility_code.seq_code_id(+)
and b.ACCT_SAVINGS_TYPE = bene.seq_code_id(+)
and m.LANGUAGE_PREF = language_codes.seq_code_id(+)</stringProp>

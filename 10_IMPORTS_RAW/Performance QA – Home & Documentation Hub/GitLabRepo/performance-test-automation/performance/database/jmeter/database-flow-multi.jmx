        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getCs529PortfolioPhaseData" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">         SELECT tf.traunch_id,
           fp.fund_id,
           fp.seq_phase_id,
           fp.phase_from,
           fp.phase_to,
           fp.description,
           fp.phase_category,
           nvl(fp.YEARS_TO_COLLEGE_START, -1) YEARS_TO_COLLEGE_START,
           nvl(fp.YEARS_TO_COLLEGE_END, -1) YEARS_TO_COLLEGE_END,
           etxn.txntype,
           etxn.eligible,
           NULL SEQ_BREAKPOINT_SCH_ID,
           NULL TABLE_SEQ,
           NULL POWERAGENT_TABLE_NUM,
           NULL DATE_FROM,
           NULL DATE_TO,
           NULL BREAKPOINT_DESCRIPTION ,
           NULL SALES_CHARGE,
           NULL DEALER_COMM,
           NULL DISPLAY_ORDER,
           NULL GRAND_FATHER_FLAG,
           &apos;fundPhase&apos; ENTITY_TYPE
      FROM tu_traunch_fund tf,
           tu_fund_phase fp,
           tu_eligible_txns etxn,
           tu_traunch t
     WHERE     tf.traunch_id = t.traunch_id
           AND fp.fund_id = tf.fund_id
           AND fp.seq_phase_id = etxn.seq_phase_id
           AND NVL (t.ctl_rec_stat, &apos;A&apos;) = &apos;A&apos;
    UNION ALL
    SELECT tf.TRAUNCH_ID,
           tf.FUND_ID,
           NULL seq_phase_id,
           NULL phase_from,
           NULL phase_to,
           NULL description,
           NULL phase_category,
           -1 YEARS_TO_COLLEGE_START,
           -1 YEARS_TO_COLLEGE_END,
           NULL txntype,
           NULL eligible,
           bs.SEQ_BREAKPOINT_SCH_ID,
           bs.TABLE_SEQ,
           bs.POWERAGENT_TABLE_NUM,
           bs.DATE_FROM,
           bs.DATE_TO,
           bs.DESCRIPTION BREAKPOINT_DESCRIPTION,
           bs.SALES_CHARGE,
           bs.DEALER_COMM,
           bs.DISPLAY_ORDER,
           bs.GRAND_FATHER_FLAG,
           &apos;breakPoint&apos; ENTITY_TYPE
      FROM TENV_BREAKPOINT_SCH bs,
           TENV_FUND_BREAKPOINT_SCH_XREF fbs,
           TU_TRAUNCH_FUND tf,
           tu_traunch t
     WHERE     bs.TABLE_SEQ = fbs.TABLE_SEQ
           AND fbs.CTL_REC_STAT = &apos;A&apos;
           AND bs.CTL_REC_STAT = &apos;A&apos;
           AND fbs.FUND_ID = tf.FUND_ID
           AND tf.TRAUNCH_ID = t.traunch_id
           AND NVL (t.ctl_rec_stat, &apos;A&apos;) = &apos;A&apos;
    ORDER BY TRAUNCH_ID,
             FUND_ID,
             TABLE_SEQ,
             DISPLAY_ORDER
</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">CNT</stringProp>
        </JDBCSampler>

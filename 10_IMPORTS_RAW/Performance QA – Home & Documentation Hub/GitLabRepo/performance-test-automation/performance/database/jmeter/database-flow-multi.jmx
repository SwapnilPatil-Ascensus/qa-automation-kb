        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getDormancyDetailsByMemberId" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        select MAX(LAST_PROFILE_CHANGE_DATE) &quot;lastProfileChangeDate&quot;,
        	   MAX(LAST_FIN_TRANSACTION_DATE) &quot;lastFinTxnDate&quot;,
        	   MAX(LAST_AIP_CONTRIBUTION_DATE) &quot;lastAipContributionDate&quot;,
        	   MAX(LAST_PAYROLL_CONTRIBUTION_DATE) &quot;lastPayrollContributionDate&quot;,
        	   MAX(LAST_MEMBER_LOGIN_DATE) &quot;lastMemberLoginDate&quot;,
        	   MAX(LAST_PHONE_CONTACT_DATE) &quot;lastPhoneContactDate&quot;,
        	   MAX(LAST_IVR_DATE) &quot;lastIVRDate&quot;,
        	   MAX(LAST_SWP_DATE) &quot;lastSWPDate&quot;,
        	   MAX(LAST_SYS_EXCHANGE_DATE) &quot;lastSysExchangeDate&quot;
        from TU_DORMANCY d,
        	 TU_ACCT a
        where a.seq_acct_id = d.seq_acct_id
         	and a.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;
        group by a.uii_member_id</stringProp>

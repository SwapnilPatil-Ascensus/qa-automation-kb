          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: pendingEftSql" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">SELECT DISTINCT b.seq_bnk_id, b.NAME, b.BANK_NICK_NAME, b.ROUTING_NUM, b.ACCT_NUM, b.ACCT_TYPE,
b.STATUS AS bankstatus, b.BANK_PHONE, b.IS_DOMESTIC, bi.seq_pay_id, bi.BEGIN_DATE, bi.DEBIT_DATE, bi.SEQ_ACCT_ID,
bi.PAYMENT_TYPE, bi.FREQUENCY, bi.AMOUNT, bi.WEB, bi.status, bi.RUN_DAY, bi.CHANGE_ID,
bi.CTL_UPD_DTTM MODIFIED_DATE, bi.CTL_INS_DTTM CREATE_DATE, bi.BANK_CHANGE_ID, bi.TAX_YEAR, bi.EBT_INITIATED_DATE,
b.PRI_OWNER_FIRST_NAME, b.PRI_OWNER_MIDDLE_INITIAL,b.PRI_OWNER_LAST_NAME,b.SEC_OWNER_FIRST_NAME,b.SEC_OWNER_MIDDLE_INITIAL,b.SEC_OWNER_LAST_NAME,b.WITHDRAWAL_ELIGIBLE
FROM TU_BANK_HIST b, TU_BNK_INSTRUCTION bi, TU_ACCT a, tu_traunch tr
WHERE a.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
AND a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
AND bi.seq_acct_id = a.seq_acct_id
AND bi.seq_bnk_id = b.seq_bnk_id
AND bi.bank_change_id = b.change_id
AND bi.payment_type=&apos;O&apos;
AND a.TRAUNCH_ID = tr.traunch_id
AND (tr.BRANDING = &apos;ohio&apos; or tr.PRODUCT_TYPE = &apos;ABLE&apos; or bi.DEBIT_DATE &gt; tr.asof_date)
AND ((bi.status = &apos;A&apos; AND bi.DEBIT_DATE &gt; tr.asof_date
AND not exists
(select &apos;x&apos; from TU_ACH_OUT ao, tu_fin_txn f
where ao.seq_fin_txn_id = f.seq_fin_txn_id
AND f.SEQ_ACCT_ID = a.SEQ_ACCT_ID
AND ao.seq_pay_id = bi.seq_pay_id
AND f.fin_type = &apos;EBT&apos;)
)
OR (exists
(select &apos;x&apos; from TU_ACH_OUT ao, tu_fin_txn f
where ao.seq_fin_txn_id = f.seq_fin_txn_id
AND f.SEQ_ACCT_ID = a.SEQ_ACCT_ID
AND ao.seq_pay_id = bi.seq_pay_id
AND f.fin_type = &apos;EBT&apos;
AND f.web_display = &apos;Y&apos;
AND ((f.ctl_rec_stat IN (&apos;O&apos;,&apos;Q&apos;, &apos;S&apos;, &apos;P&apos;, &apos;M&apos;, &apos;E&apos;, &apos;I&apos;, &apos;B&apos;, &apos;D&apos;))
OR
(f.ctl_rec_stat = &apos;R&apos; AND TRUNC(tr.asof_date)&lt;TRUNC(f.run_date))))
))
ORDER BY bi.debit_date, bi.frequency</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>

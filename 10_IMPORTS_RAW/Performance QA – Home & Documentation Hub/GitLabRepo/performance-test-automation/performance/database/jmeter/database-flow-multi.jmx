          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getYearlyContribs (DST)" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">		SELECT a.TRAUNCH_ID,
            a.uii_acct_id, a.uii_acct_ext, o.CONTRIB_YEAR AS tax_year,
            SUM(o.AMOUNT * t.change_factor) AS value
        FROM
            TDST_ACCT_TXN o, TDST_TXN_TYPE t, tu_acct a
        WHERE
            o.seq_acct_id = a.seq_acct_id AND
            a.uii_acct_id= &apos;${__V(A_UII_ACCT_ID_${count})}&apos;  AND
            a.uii_acct_ext= &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;  AND
            o.CONTRIB_YEAR &gt;= &apos;2023&apos;  AND
            o.SEQ_DST_TXN_TYPE_ID = t.SEQ_DST_TXN_TYPE_ID AND
            t.display_hist=&apos;Y&apos; AND
            t.uii_tran_code = &apos;1000&apos;
        GROUP BY
            a.TRAUNCH_ID, a.uii_acct_id, a.uii_acct_ext, o.CONTRIB_YEAR</stringProp>

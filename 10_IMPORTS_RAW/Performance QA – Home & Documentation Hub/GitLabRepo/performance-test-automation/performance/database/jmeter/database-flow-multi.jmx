        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getSecurityImage" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        select
			E_LOGON_IMG, LOGON_IMG_CI, E_PASS_PHRASE, PASS_PHRASE_CI, USERNAME
        from
            TA_LOGIN
        where
            upper(USERNAME) = upper(&apos;${username}&apos;)

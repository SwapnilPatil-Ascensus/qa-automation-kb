          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getSinceInceptionCashFlowsForENVISION" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">    select   asofdate &quot;asOfDate&quot;, totalbalance &quot;asOfDateBalance&quot;,
             y_balance &quot;yearlyBalance&quot;, y_date &quot;yearlyBalanceDate&quot;,
             irryear &quot;irrYear&quot;
    from
    (select txn.seq_acct_id, trunc (trade_date) asofdate,
             sum (nvl(txn.gross_amount,0) * txn.change_factor) totalbalance,
             y.y_balance y_balance, y.y_date y_date, 100 irryear
        from tenv_acct_txn txn,
             tenv_txn_type ty,
             tenv_traunch_txn_type tty,
             (with buz as
                   (select min (trade_date) buz_date
                      from (  select trade_date
                                from tenv_acct_txn txn
                               where txn.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                                group by trade_date
                                having sum (nvl (txn.shares, 0) * txn.change_factor) &gt; 0))
              select seq_acct_id, y_balance, y_date
                from (select seq_acct_id, max (b.buz_date) y_date,
                               sum (nvl(t.shares,0) * t.change_factor * p.fund_price) y_balance
                          from tenv_acct_txn t,
                               tenv_txn_type ty,
                               tenv_traunch_txn_type tty,
                               buz b,
                               (select fp.fund_id, fp.price fund_price
                                  from tu_fund_price fp, tu_funds f, buz b
                                 where fp.fund_id = f.fund_id  and f.fund_type not in(&apos;B&apos;,&apos;C&apos;,&apos;D&apos;)
                                   and fp.price_date = (select max(p2.price_date)
                                                            from tu_fund_price p2 where p2.price_date &lt;= trunc(b.buz_date)
                                                            and fp.fund_id = p2.fund_id group by p2.fund_id)) p
                         where t.seq_env_txn_type_id = ty.seq_env_txn_type_id
                           and ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
                           and t.traunch_id = tty.traunch_id
                           and t.fund_id = p.fund_id
                           and tty.display_hist = &apos;Y&apos;
                           and t.trade_date &lt;= b.buz_date
                      group by seq_acct_id)) y
       where txn.seq_acct_id = y.seq_acct_id
         and txn.seq_env_txn_type_id = ty.seq_env_txn_type_id
         and ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
         and txn.traunch_id = tty.traunch_id
         and tty.display_hist = &apos;Y&apos;
         and trade_date between trunc(y_date+1) and trunc(sysdate - 3 )
         and y.y_balance &gt; 0
         and txn.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
    group by txn.seq_acct_id, txn.trade_date, y.y_balance, y.y_date
    union all
              select   a.seq_acct_id, max (TRUNC (sysdate - 3 )) asofdate,
                       sum (round (fb.total_units * fp.price, 2)) totalbalance,
                       sum (0) y_balance, max (TRUNC (sysdate - 3 )) as y_date, 0 irryear
                  from tu_acct a,
                       tu_fund_balance fb,
                       tu_fund_price_web fp,
                       tu_funds f
                 where a.seq_acct_id = fb.seq_acct_id
                   and fb.fund_id = fp.fund_id  and f.fund_type not in(&apos;B&apos;,&apos;C&apos;,&apos;D&apos;)
                   and fp.fund_id = f.fund_id
                   and f.web_status = &apos;A&apos;
                   and f.back_status = &apos;A&apos;
                   and a.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
              group by a.seq_acct_id, fp.price_date
    )
    order by irryear, asofdate</stringProp>

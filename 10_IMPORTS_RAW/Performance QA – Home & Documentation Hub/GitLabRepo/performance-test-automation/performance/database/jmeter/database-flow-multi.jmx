          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAccountFunds" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">select al.fund_id,
al.percent_alloc,
al.ctl_ins_dttm,
al.ctl_upd_dttm,
al.sync_state,
al.realloc_date,
al.change_id,
al.elec_type,
al.ctl_upd_dttm,
al.sync_state,
al.realloc_date,
al.change_id,
al.elec_type,
f.fund_name,
f.fund_desc,
f.omni_fund_id,
f.class_type,
f.class_sub_type,
f.classification,
f.fund_type ,
nvl(fw.price,0.0) price,
f.display_order,
f.allows_new_investment,

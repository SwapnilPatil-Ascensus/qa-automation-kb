            <stringProp name="query">        SELECT
        	&apos;INT_PARTY&apos; &quot;TYPE&quot;, I.SEQ_PERSON_ID, I.SEQ_ACCT_ID, I.STATUS, I.STMT_COPIES_FLAG, I.PROFILE_STMT_COPIES_FLAG,
        	null &quot;ACCESS_LEVEL&quot;, null &quot;GSP_PIN&quot;, I.ACTVTY_CNFRM_COPIES_FLAG, I.SYNC_STATE, I.STOP_MAIL,
        	(select REL_DESC from TU_RELATIONSHIP where SEQ_REL_ID = I.SEQ_REL_ID) RELATIONSHIP,
        	null &quot;TRANS_LEVEL&quot;,
        	null &quot;AUTHORIZATION_TYPE&quot;,
        	P.DOB, P.TITLE, P.FIRST_NAME, P.MIDDLE_INITIAL, P.LAST_NAME, P.SUFFIX,
        	P.ML_ADDLINE1, P.ML_ADDLINE2, P.ML_ADDLINE3, P.ML_CITY, P.ML_ZIPCODE, P.ML_STATELABEL, P.IS_FOREIGN_ADDRESS,
        	P.SSN_E, P.SSN_CI, P.WORK_PHONE, P.HOME_PHONE, P.CTL_INS_DTTM, P.CTL_UPD_DTTM, P.SYNC_STATE, P.CHANGE_ID,
        	null &quot;EFFECTIVE_DATE&quot;, null &quot;EXPIRATION_DATE&quot;
        from
        	TU_INTPARTY I, TU_PERSON P
        where
        	P.SEQ_PERSON_ID = I.SEQ_PERSON_ID
        	and (I.status != &apos;X&apos; or I.status is null)
        	and P.CTL_REC_STAT != &apos;X&apos; and
            I.SEQ_ACCT_ID = (
        		select seq_acct_id from tu_acct where uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;
        		and uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
        	)
        union all
        SELECT
        	&apos;AUTH_AGENT&apos; &quot;TYPE&quot;, I.SEQ_PERSON_ID, I.SEQ_ACCT_ID, I.STATUS, I.STMT_COPIES_FLAG, null,
        	I.ACCESS_LEVEL, I.GSP_PIN, null, I.SYNC_STATE, I.STOP_MAIL,
        	(select REL_DESC from TU_RELATIONSHIP where SEQ_REL_ID = I.RELATIONSHIP_ID) RELATIONSHIP,
        	(SELECT AA_TRANS_LEVEL FROM TU_MEMBER WHERE UII_MEMBER_ID =
        		(SELECT UII_MEMBER_ID FROM TU_ACCT WHERE SEQ_ACCT_ID = I.SEQ_ACCT_ID)) TRANS_LEVEL,
        	(select REL_DESC from TU_RELATIONSHIP where SEQ_REL_ID = I.SEQ_REL_ID) AUTHORIZATION_TYPE,
        	P.DOB, P.TITLE, P.FIRST_NAME, P.MIDDLE_INITIAL, P.LAST_NAME, P.SUFFIX,
        	P.ML_ADDLINE1, P.ML_ADDLINE2, P.ML_ADDLINE3, P.ML_CITY, P.ML_ZIPCODE, P.ML_STATELABEL, P.IS_FOREIGN_ADDRESS,
        	P.SSN_E, P.SSN_CI, P.WORK_PHONE, P.HOME_PHONE, P.CTL_INS_DTTM, P.CTL_UPD_DTTM, P.SYNC_STATE, P.CHANGE_ID,
        	I.EFFECTIVE_DATE, I.EXPIRATION_DATE
        from
        	TU_AUTHORIZED_AGENT I, TU_PERSON P
        where
        	P.SEQ_PERSON_ID = I.SEQ_PERSON_ID
        	and (I.status != &apos;X&apos; or I.status is null)
        	and P.CTL_REC_STAT != &apos;X&apos;
        	and I.SEQ_ACCT_ID = (
        		select seq_acct_id from tu_acct where uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;
        		and uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
        	)</stringProp>

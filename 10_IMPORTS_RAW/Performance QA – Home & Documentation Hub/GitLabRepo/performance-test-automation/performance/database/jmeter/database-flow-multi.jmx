          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: acct_stmt_summary" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">     SELECT
	    /*+ ORDERED */
	    f.OMNI_FUND_ID
	  , FB.TOTAL_UNITS SHARES
	  , FP.PRICE       PRICE
	  , FP.PRICE_DATE  ASOFDATE
	  , f.FUND_ID
	  , f.fund_type
	  , f.DISPLAY_ORDER
	  , f.CLASS_TYPE
	  , f.class_sub_type
	  , f.CLASSIFICATION
	  , f.cusip
	FROM
	    TU_ACCT         A
	  , TU_FUND_BALANCE FB
	  , TU_FUND_PRICE   FP
	  , TU_FUNDS        F
	WHERE
	    A.TRAUNCH_ID       = &apos;${__V(A_TRAUNCH_ID_${count})}&apos;
	    AND A.UII_ACCT_ID  = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
	    AND A.UII_ACCT_EXT = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
	    AND A.SEQ_ACCT_ID  = FB.SEQ_ACCT_ID
	    AND FB.FUND_ID     = FP.FUND_ID
	    AND F.FUND_ID      = FP.FUND_ID
	    AND F.FUND_TYPE NOT IN (&apos;B&apos;
	                          ,&apos;C&apos;
	                          , &apos;D&apos;)
	    AND FP.PRICE_DATE =
	    (
	        SELECT
	            MAX(P2.PRICE_DATE)
	        FROM
	            TU_FUND_PRICE P2
	        WHERE
	            P2.PRICE_DATE &lt;= TRUNC(to_date(&apos;02/13/2024&apos;, &apos;MM/DD/YYYY&apos;))
	            AND fP.fund_id = P2.fund_id
	    )
	ORDER BY
	    f.DISPLAY_ORDER</stringProp>

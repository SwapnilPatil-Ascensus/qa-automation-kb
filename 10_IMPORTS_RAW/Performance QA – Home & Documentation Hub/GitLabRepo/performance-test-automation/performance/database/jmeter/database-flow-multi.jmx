          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: retrieveSingleBranch" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        SELECT b.seq_branch_id,
            b.seq_dealer_id,
            b.branch_name,
            b.rk_ext_id,
            trcd.code_id AS territory_id,
            b.phone_number,

         rel.seq_rep_id				seq_rep_id,
         emp.seq_employer_id		emp_employer_id,
         m.responsive_site_popup responsive_site_popup,
         a.GSP_SAGE_BONUS_IND  a_gsp_sage_bonus_ind,
         a.GSP_SAGE_ENROLL_DT a_gsp_sage_enroll_dt,
         a.SAGE_REWARD_IND a_sage_reward_ind,

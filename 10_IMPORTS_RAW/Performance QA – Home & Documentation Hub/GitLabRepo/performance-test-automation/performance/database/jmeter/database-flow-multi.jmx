          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getStandardYearlyBalancesForENVISIONnPreConv" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">    select   nvl(y_balance,0) &quot;yearlyBalance&quot;, y_date &quot;yearlyBalanceDate&quot;, irryear &quot;irrYear&quot;
        from (
        select seq_acct_id, sum(nvl(y_balance,0)) y_balance, y_date, 1 irryear
        from (with buz as (
                      select trunc (max (calendar_date)) buz_date,  max (add_months (trunc (sysdate - 3 ), -12 )) y_date
                        from tu_calendar
                       where calendar_date &lt;= add_months (trunc (sysdate - 3 ), -12 )  and holiday_flag = &apos;N&apos; and stock_flag = &apos;N&apos;)
            select seq_acct_id, nvl(y_balance,0) y_balance, y_date
            from (
            select seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * t.change_factor * p.fund_price) y_balance
                    from tenv_acct_txn t, tenv_txn_type ty, tenv_traunch_txn_type tty, tu_fin_type_source ts, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_env_txn_type_id = ty.seq_env_txn_type_id
                       and ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
                       and t.traunch_id = tty.traunch_id
                       and ty.seq_fin_type_source_id = ts.seq_fin_type_source_id
                       and t.fund_id = p.fund_id
                       and tty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
            union
            select   seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor * p.fund_price) y_balance
                    from tdst_acct_txn t, tdst_txn_type ty, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_dst_txn_type_id = ty.seq_dst_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
              union
                    select  t.seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor  * fund_price) y_balance
                      from tu_bsd_acct_txn t, tu_bsd_txn_type ty, buz b,
                           (select fp.fund_id, fp.price fund_price
                              from tu_fund_price fp, tu_funds f, buz b
                             where fp.fund_id = f.fund_id
                               and fp.price_date =  (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                               ) p
                     where t.seq_bsd_txn_type_id = ty.seq_bsd_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by t.seq_acct_id
              )) group by seq_acct_id, y_date
    union all
        select seq_acct_id, sum(nvl(y_balance,0)) y_balance, y_date, 3 irryear
        from (with buz as (
                      select trunc (max (calendar_date)) buz_date,  max (add_months (trunc (sysdate - 3 ), -36 )) y_date
                        from tu_calendar
                       where calendar_date &lt;= add_months (trunc (sysdate - 3 ), -36 )  and holiday_flag = &apos;N&apos; and stock_flag = &apos;N&apos;)
            select seq_acct_id, nvl(y_balance,0) y_balance, y_date
            from (
            select seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * t.change_factor * p.fund_price) y_balance
                    from tenv_acct_txn t, tenv_txn_type ty, tenv_traunch_txn_type tty, tu_fin_type_source ts, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_env_txn_type_id = ty.seq_env_txn_type_id
                       and ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
                       and t.traunch_id = tty.traunch_id
                       and ty.seq_fin_type_source_id = ts.seq_fin_type_source_id
                       and t.fund_id = p.fund_id
                       and tty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
            union
            select   seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor * p.fund_price) y_balance
                    from tdst_acct_txn t, tdst_txn_type ty, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_dst_txn_type_id = ty.seq_dst_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
              union
                    select  t.seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor  * fund_price) y_balance
                      from tu_bsd_acct_txn t, tu_bsd_txn_type ty, buz b,
                           (select fp.fund_id, fp.price fund_price
                              from tu_fund_price fp, tu_funds f, buz b
                             where fp.fund_id = f.fund_id
                               and fp.price_date =  (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                               ) p
                     where t.seq_bsd_txn_type_id = ty.seq_bsd_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos; 
                    group by t.seq_acct_id
              )) group by seq_acct_id, y_date
    union all
        select seq_acct_id, sum(nvl(y_balance,0)) y_balance, y_date, 5 irryear
        from (with buz as (
                      select trunc (max (calendar_date)) buz_date,  max (add_months (trunc (sysdate - 3 ), -60 )) y_date
                        from tu_calendar
                       where calendar_date &lt;= add_months (trunc (sysdate - 3 ), -60 )  and holiday_flag = &apos;N&apos; and stock_flag = &apos;N&apos;)
            select seq_acct_id, nvl(y_balance,0) y_balance, y_date
            from (
            select seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * t.change_factor * p.fund_price) y_balance
                    from tenv_acct_txn t, tenv_txn_type ty, tenv_traunch_txn_type tty, tu_fin_type_source ts, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_env_txn_type_id = ty.seq_env_txn_type_id
                       and ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
                       and t.traunch_id = tty.traunch_id
                       and ty.seq_fin_type_source_id = ts.seq_fin_type_source_id
                       and t.fund_id = p.fund_id
                       and tty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
            union
            select   seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor * p.fund_price) y_balance
                    from tdst_acct_txn t, tdst_txn_type ty, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_dst_txn_type_id = ty.seq_dst_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
              union
                    select  t.seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor  * fund_price) y_balance
                      from tu_bsd_acct_txn t, tu_bsd_txn_type ty, buz b,
                           (select fp.fund_id, fp.price fund_price
                              from tu_fund_price fp, tu_funds f, buz b
                             where fp.fund_id = f.fund_id
                               and fp.price_date =  (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                               ) p
                     where t.seq_bsd_txn_type_id = ty.seq_bsd_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by t.seq_acct_id
              ))  group by seq_acct_id, y_date
    union all
        select seq_acct_id, sum(nvl(y_balance,0)) y_balance, y_date, 10 irryear
        from (with buz as (
                      select trunc (max (calendar_date)) buz_date,  max (add_months (trunc (sysdate - 3 ), -120 )) y_date
                        from tu_calendar
                       where calendar_date &lt;= add_months (trunc (sysdate - 3 ), -120 )  and holiday_flag = &apos;N&apos; and stock_flag = &apos;N&apos;)
            select seq_acct_id, nvl(y_balance,0) y_balance, y_date
            from (
            select seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * t.change_factor * p.fund_price) y_balance
                    from tenv_acct_txn t, tenv_txn_type ty, tenv_traunch_txn_type tty, tu_fin_type_source ts, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_env_txn_type_id = ty.seq_env_txn_type_id
                       and ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
                       and t.traunch_id = tty.traunch_id
                       and ty.seq_fin_type_source_id = ts.seq_fin_type_source_id
                       and t.fund_id = p.fund_id
                       and tty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
            union
            select   seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor * p.fund_price) y_balance
                    from tdst_acct_txn t, tdst_txn_type ty, buz b,
                       (select fp.fund_id, fp.price fund_price
                          from tu_fund_price fp, tu_funds f, buz b
                         where fp.fund_id = f.fund_id
                           and fp.price_date = (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                        ) p
                     where t.seq_dst_txn_type_id = ty.seq_dst_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by seq_acct_id
              union
                    select  t.seq_acct_id, max (b.y_date) y_date, sum (nvl(t.shares,0) * ty.change_factor  * fund_price) y_balance
                      from tu_bsd_acct_txn t, tu_bsd_txn_type ty, buz b,
                           (select fp.fund_id, fp.price fund_price
                              from tu_fund_price fp, tu_funds f, buz b
                             where fp.fund_id = f.fund_id
                               and fp.price_date =  (select max(p2.price_date)
                                                        from tu_fund_price p2
                                                        where p2.price_date &lt;= trunc(b.buz_date)
                                                        and fp.fund_id = p2.fund_id group by p2.fund_id)
                               ) p
                     where t.seq_bsd_txn_type_id = ty.seq_bsd_txn_type_id
                       and t.fund_id = p.fund_id
                       and ty.display_hist = &apos;Y&apos;
                       and t.trade_date &lt;= b.buz_date
                       and t.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                    group by t.seq_acct_id
              ))  group by seq_acct_id, y_date
    union all
        select   a.seq_acct_id, sum (round (nvl(fb.total_units,0) * fp.price, 2)) y_balance,
                           max (trunc (sysdate - 3 )) y_date, 0 irryear
                      from tu_acct a,
                           tu_fund_balance fb,
                           tu_fund_price_web fp,
                           tu_funds f
                     where a.seq_acct_id = fb.seq_acct_id
                       and fb.fund_id = fp.fund_id
                       and fp.fund_id = f.fund_id
                       and f.web_status = &apos;A&apos;
                       and f.back_status = &apos;A&apos;
                       and a.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
                  group by a.seq_acct_id, fp.price_date
                  ) p,
            tu_acct a
        where a.seq_acct_id       = p.seq_acct_id
              and a.seq_acct_id   = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
        order by irryear</stringProp>

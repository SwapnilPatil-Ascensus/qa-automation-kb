          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getRestrictionAndFreezeConstraints" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select
            tc.type,
            tc.description,
            tc.code_id,
            tac.freeze_date,
            NULL ctl_upd_dttm,
            tac.csr_id,
            tac.seq_acct_id,
            NULL uii_member_id
        from
            TU_ACCT_CONSTRAINT tac, TU_CODES tc
        where
             tac.seq_acct_id in 
            ( select seq_acct_id from tu_acct where uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos; )
            and tc.seq_code_id = tac.seq_code_id and nvl(tac.ctl_rec_stat, &apos;A&apos;) != &apos;X&apos;
            and UPPER(tc.description) NOT LIKE &apos;%NONE%&apos;
        union all
        select
            tc.type,
            tc.description,
            tc.code_id,
            NULL freeze_date,
            tac.ctl_upd_dttm,
            tac.csr_id,
            NULL seq_acct_id,
            tac.uii_member_id
        from
            TU_MEMBER_CONSTRAINT tac, TU_CODES tc
        where
            tac.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;
            and tc.seq_code_id = tac.seq_code_id and nvl(tac.ctl_rec_stat, &apos;A&apos;) != &apos;X&apos;
            and tc.type = &apos;RESTR&apos;
            and UPPER(tc.description) NOT LIKE &apos;%NONE%&apos;</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">CNT</stringProp>
          </JDBCSampler>

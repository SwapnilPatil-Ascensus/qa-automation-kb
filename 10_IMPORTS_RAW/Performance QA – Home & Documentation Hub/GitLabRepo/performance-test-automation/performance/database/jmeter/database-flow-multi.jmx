        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAccountSponsorByMemberId" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        SELECT 
        	distinct(a.uii_acct_id||&apos;-&apos;||a.uii_acct_ext||&apos;: &apos;||s.SPONSOR_NAME)
        FROM 
	        TU_BOOST_RECIPIENT br,
			TU_BOOST_RECIPIENT_PROGRAM rp,
			TU_BOOST_PROGRAM b,
			TU_BOOST_SPONSOR s,
			TU_ACCT a
		WHERE 
			br.SEQ_BOOST_RECIPIENT_ID = rp.SEQ_BOOST_RECIPIENT_ID
			AND rp.SEQ_BOOST_PROGRAM_ID = b.SEQ_BOOST_PROGRAM_ID
			AND b.SEQ_BOOST_SPONSOR_ID = s.SEQ_BOOST_SPONSOR_ID
			and a.SEQ_ACCT_ID = br.SEQ_ACCT_ID
			and s.CTL_REC_STAT = &apos;A&apos;
			and b.CTL_REC_STAT = &apos;A&apos;
			and br.CTL_REC_STAT = &apos;A&apos;
			and rp.CTL_REC_STAT = &apos;A&apos;
			AND a.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>

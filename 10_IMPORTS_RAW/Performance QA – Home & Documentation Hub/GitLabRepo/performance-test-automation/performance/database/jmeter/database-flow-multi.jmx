         m.language_pref language_pref,
         m.mkt_txt_opt_in mkt_txt_opt_in,
         m.adm_enable adm_enabled         
      FROM tu_acct a, tu_person p, tu_bene b,
            tu_successor s, tu_traunch t,
            tu_member m, tu_codes tc,
            tu_acct_closed ac , tu_closed_reason cr, tu_avatar_image ai,
        	tu_member_employer me,
        	tu_employer emp,
        	TU_EMPLOYER_REP_REL rel
      WHERE a.seq_part_id = p.seq_person_id
         AND a.seq_bene_id = b.seq_bene_id
         AND a.seq_sx_id = s.seq_sx_id
         AND  a.traunch_id = t.traunch_id
         AND a.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos; 
         AND  m.uii_member_id = a.uii_member_id
         and nvl(enroll_status,&apos;A&apos;)!=&apos;R&apos;
         and a.seq_acct_id = ac.seq_acct_id(+)
         and ac.seq_closed_reason_id = cr.seq_closed_reason_id(+)
         AND m.client_segment_code = tc.seq_code_id(+)
         and a.seq_avatar_image_id = ai.seq_avatar_image_id(+)
         and me.uii_member_id (+)= m.uii_member_id
         and emp.seq_employer_id (+)= me.seq_employer_id
         and rel.seq_employer_id (+)= emp.seq_employer_id
         and nvl(me.ctl_rec_stat(+), &apos;A&apos;) != &apos;X&apos;
     ORDER BY a.seq_acct_id</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>

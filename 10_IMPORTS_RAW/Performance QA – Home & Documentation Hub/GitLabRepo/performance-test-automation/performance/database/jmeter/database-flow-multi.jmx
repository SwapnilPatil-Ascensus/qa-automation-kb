        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getCs529PortfolioData" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">    SELECT /*+ ORDERED INDEX(TF PK_U_TRAUNCH_FUND) INDEX(F PK_U_FUNDS) */
           null risk_id,
           null fundmgr_id,
           tf.traunch_id,
           f.fund_id,
           f.omni_fund_id,
           f.category,
           f.web_status,
           f.back_status,
           f.guaranteed_return,
           f.multi_phased,
           f.maturity_type,
           f.maturity_date,
           f.maturity_term,
           f.fund_type,
           null years_to_college_start,
           null years_to_college_end,
           f.classification,
           null name,
           null description,
           f.fund_name,
           f.fund_desc,
           f.display_order,
           f.int_accrual_status,
           f.learn_more_url,
           f.performance_url,
           f.int_rate,
           f.class_type,
           f.enroll_desc,
           f.allows_new_investment,
           f.dst_cusip,
           f.price_perform,
           f.price_id,
           f.cusip,
           f.class_sub_type,
           &apos;Static&apos; fund_class_type,
           f.price_perform_desc,
           f.CLOSED_TO_NEW_SHAREHOLDERS
      FROM tu_traunch_fund tf, tu_funds f, tu_traunch t
     WHERE tf.traunch_id = t.traunch_id
        AND f.fund_id = tf.fund_id AND f.fund_type &lt;&gt; &apos;A&apos;
        AND NVL(t.ctl_rec_stat,&apos;A&apos;) = &apos;A&apos;
    union all
      SELECT /*+ ORDERED INDEX(TF PK_U_TRAUNCH_FUND) INDEX(F PK_U_FUNDS) INDEX(TC PK_TU_AGE_BASED) INDEX(TT PK_TU_RISK_TOLERANCE) INDEX(TR PK_TU_RISK_AGE_FUND) */
            tr.risk_id,
             f.fundmgr_id,
             tf.traunch_id,
             f.fund_id,
             f.omni_fund_id,
             f.category,
             f.web_status,
             f.back_status,
             f.guaranteed_return,
             f.multi_phased,
             f.maturity_type,
             f.maturity_date,
             f.maturity_term,
             f.fund_type,
             tc.years_to_college_start,
             tc.years_to_college_end,
             f.classification,
             tt.name,
             tt.description,
             f.fund_name,
             f.fund_desc,
             f.display_order,
             f.int_accrual_status,
             f.learn_more_url,
             f.performance_url,
             f.int_rate,
             f.class_type,
             f.enroll_desc,
             f.allows_new_investment,
             f.dst_cusip,
             f.price_perform,
             f.price_id,
             f.cusip,
             f.class_sub_type,
             &apos;AgeBased&apos; fund_class_type,
             f.price_perform_desc,
             f.CLOSED_TO_NEW_SHAREHOLDERS
        FROM tu_traunch_fund tf,
             tu_funds f,
             tu_risk_age_fund tr,
             tu_age_based_classification tc,
             tu_risk_tolerance tt,
             tu_traunch t
       WHERE     tf.traunch_id = t.traunch_id
             AND f.fund_id = tf.fund_id
             AND f.fund_id = tr.fund_id
             AND tr.age_based_id = tc.id
             AND tr.risk_id = tt.id
             AND NVL(t.ctl_rec_stat,&apos;A&apos;) = &apos;A&apos;
             order by fund_class_type, traunch_id, fund_id
</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">CNT</stringProp>
        </JDBCSampler>

   		where
   			program.SEQ_OT_PROGRAM_ID = link.SEQ_OT_PROGRAM_ID
   			and a.seq_acct_id = link.LINKED_SEQ_ACCT_ID
   			and link.LINKED_SEQ_ACCT_ID = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
   			and link.LINK_STATUS = &apos;L&apos;</stringProp>

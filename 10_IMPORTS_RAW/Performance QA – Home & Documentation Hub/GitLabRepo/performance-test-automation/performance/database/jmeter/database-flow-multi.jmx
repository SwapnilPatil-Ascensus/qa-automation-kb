          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getSinceInceptionYearlyBalancesForENVISION" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">    	SELECT
		    y_balance &quot;yearlyBalance&quot;
		  , y_date &quot;yearlyBalanceDate&quot;
		  , irryear &quot;irrYear&quot;
		FROM
		    (
		        WITH buz AS
		            (
		                SELECT
		                    MIN (trade_date) buz_date
		                from
		                    (
		                        select
		                            trade_date
		                        FROM
		                            tenv_acct_txn         txn
		                          , tenv_traunch_txn_type tty
		                        WHERE
		                            txn.seq_acct_id      = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
		                            AND txn.traunch_id   = tty.traunch_id
		                            AND tty.display_hist = &apos;Y&apos;
		                        GROUP BY
		                            trade_date
		                        HAVING
		                            SUM (NVL (txn.shares, 0) * txn.change_factor) &gt; 0
		                    )
		            )
		        SELECT DISTINCT
		            y.seq_acct_id
		          ,
		            (
		                CASE
		                    WHEN y_date &gt;= TRUNC (sysdate - 3 , &apos;SYYYY&apos;)
		                        THEN NVL (totalbalance, 0)
		                        ELSE NVL (y_balance, 0)
		                END
		            )
		            y_balance
		          , y_date
		          , 100 irryear
		        FROM
		            (
		                SELECT
		                    txn.seq_acct_id
		                  , TRUNC (trade_date)                                  asofdate
		                  , SUM (NVL (txn.gross_amount, 0) * txn.change_factor) totalbalance
		                FROM
		                    tenv_acct_txn         txn
		                  , tenv_txn_type         ty
		                  , tenv_traunch_txn_type tty
		                  , buz                   b
		                WHERE
		                    txn.seq_env_txn_type_id    = ty.seq_env_txn_type_id
		                    AND ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
		                    AND txn.traunch_id         = tty.traunch_id
		                    AND tty.display_hist       = &apos;Y&apos;
		                    AND TRUNC (trade_date)     = TRUNC (b.buz_date)
		                    AND txn.seq_acct_id        = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
		                GROUP BY
		                    txn.seq_acct_id
		                  , txn.trade_date
		            )
		            ytd_cntrb
		          , (
		                SELECT
		                    seq_acct_id
		                  , MAX (b.buz_date)                                         y_date
		                  , SUM (NVL (t.shares, 0) * t.change_factor * p.fund_price) y_balance
		                FROM
		                    tenv_acct_txn         t
		                  , tenv_txn_type         ty
		                  , tenv_traunch_txn_type tty
		                  , buz                   b
		                  , (
		                        SELECT
		                            fp.fund_id
		                          , fp.price fund_price
		                        FROM
		                            tu_fund_price fp
		                          , tu_funds      f
		                        WHERE
		                            fp.fund_id        = f.fund_id
		                            AND fp.price_date =
		                            (
		                                SELECT
		                                    MAX (p2.price_date)
		                                FROM
		                                    tu_fund_price p2
		                                  , buz           b
		                                WHERE
		                                    p2.price_date &lt;= TRUNC (b.buz_date)
		                                    AND fp.fund_id = p2.fund_id
		                                group by
		                                    p2.fund_id
		                            )
		                    )
		                    p
		                WHERE
		                    t.seq_env_txn_type_id      = ty.seq_env_txn_type_id
		                    AND ty.seq_env_txn_type_id = tty.seq_env_txn_type_id
		                    AND t.traunch_id           = tty.traunch_id
		                    AND t.fund_id              = p.fund_id
		                    AND tty.display_hist       = &apos;Y&apos;
		                    AND t.trade_date          &lt;= b.buz_date
		                    AND t.seq_acct_id          = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
		                GROUP BY
		                    seq_acct_id
		            )
		            y
		        WHERE
		            ytd_cntrb.seq_acct_id(+) = y.seq_acct_id
		            and y.y_balance          &gt; 0
		        UNION ALL
		        SELECT
		            a.seq_acct_id
		          , SUM (ROUND (NVL (fb.total_units, 0) * fp.price, 2))    y_balance
		          , MAX (TRUNC (sysdate - 3 ))                                     AS y_date
		          , 0                                                      irryear
		        FROM
		            tu_acct           a
		          , tu_fund_balance   fb
		          , tu_fund_price_web fp
		          , tu_funds          f
		        WHERE
		            a.seq_acct_id     = fb.seq_acct_id
		            AND fb.fund_id    = fp.fund_id
		            AND fp.fund_id    = f.fund_id
		            AND f.web_status  = &apos;A&apos;
		            AND f.back_status = &apos;A&apos;
		            AND a.seq_acct_id = &apos;${__V(A_SEQ_ACCT_ID_${count})}&apos;
		        GROUP BY
		            a.seq_acct_id
		          , fp.price_date
		    )
		ORDER BY
		    irryear</stringProp>

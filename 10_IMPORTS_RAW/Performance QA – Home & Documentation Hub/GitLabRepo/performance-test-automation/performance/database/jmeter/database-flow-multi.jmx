        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getTrustedDeviceByMemberIdCookie" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        SELECT ttft.SEQ_TWOFACTOR_TRUSTDEVICE_ID &quot;seqTwofactorTrustdeviceId&quot;,
                    ttft.SEQ_TWOFACTOR_DEVICE_ID &quot;seqTwofactorDeviceId&quot;,
                    SEQ_MEMBER_ID &quot;seqMemberId&quot;,
                    TRUSTED_DT &quot;trustedDate&quot;,
                    UNTRUSTED_DT &quot;unTrustedDate&quot;
        FROM TU_TWOFACTOR_TRUSTDEVICE ttft, TU_TWOFACTOR_DEVICE ttfd
        WHERE ttft.SEQ_MEMBER_ID = &apos;${__V(APP_MEMBER_ID_1)}&apos;
        AND ttfd.DID_COOKIE = &apos;1a91faad-7280-4106-bf74-d0b720ac1e1a&apos;
        AND UNTRUSTED_DT &gt;= sysdate
        AND ttft.CTL_REC_STAT = &apos;A&apos;
        AND ttfd.SEQ_TWOFACTOR_DEVICE_ID = ttft.SEQ_TWOFACTOR_DEVICE_ID
        AND ttfd.PLATFORM_FINGERPRINT_H = &apos;697298d440a834e8d5319345c782c2b8&apos;
        AND (ttfd.BROWSERNAME_FINGERPRINT_H = &apos;fee02d2648ada845188a39ad5ede0f1c&apos; OR ttfd.BROWSER_MAJOR_FP_H = &apos;321c137ee23eaa1e275accf944696c96&apos; )</stringProp>

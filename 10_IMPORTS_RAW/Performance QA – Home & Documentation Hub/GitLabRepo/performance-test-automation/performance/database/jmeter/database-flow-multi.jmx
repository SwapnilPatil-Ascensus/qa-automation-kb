        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getCountFraudBlockByIPAddress" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">		SELECT
			COUNT(*) CNT
		FROM 
			TU_FRAUD_BLOCK_INFO
		WHERE
			CTL_REC_STAT IN (&apos;A&apos;,&apos;R&apos;)
			AND ((TEMP_BLOCK_FLAG = &apos;Y&apos; and TEMP_BLOCK_ENDTIME &gt; sysdate) OR PERMANENT_FLAG = &apos;Y&apos;)
			AND IP_ADDRESS = &apos;206.19.51.109&apos;</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>

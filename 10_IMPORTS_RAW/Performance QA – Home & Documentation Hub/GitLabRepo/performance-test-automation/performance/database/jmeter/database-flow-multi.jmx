        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: end_balance_for_all_accounts" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">     SELECT
	        A.UII_ACCT_ID, A.UII_ACCT_EXT, SUM(ROUND(FB.TOTAL_UNITS * FP.PRICE,2)) END_BALANCE , MAX(FP.PRICE_DATE) as ASOFDATE
      FROM
	       TU_ACCT A,
	       TU_FUND_BALANCE FB,
	       TU_FUND_PRICE_WEB FP,
	       TU_FUNDS F
      WHERE A.UII_MEMBER_ID = &apos;${__V(APP_MEMBER_ID_1)}&apos;
         AND A.SEQ_ACCT_ID = FB.SEQ_ACCT_ID
         AND FB.FUND_ID = FP.FUND_ID
		 AND nvl(A.enroll_status,&apos;A&apos;)!=&apos;R&apos;
		 AND FB.FUND_ID = F.FUND_ID
		 AND F.FUND_TYPE NOT IN (&apos;B&apos;,&apos;C&apos;,&apos;D&apos;)
      GROUP BY A.UII_ACCT_ID, A.UII_ACCT_EXT</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">CNT</stringProp>
        </JDBCSampler>

          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getRebalanceDates" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        SELECT reBalanceDate
        FROM (
            SELECT distinct b.EXCHANGE_DATE reBalanceDate
                FROM TU_EXCHANGE_DATE b, tu_acct a
                WHERE b.seq_acct_id = a.seq_acct_id
                AND a.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
                AND a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
                AND nvl(b.CTL_REC_STAT,&apos;A&apos;) = &apos;A&apos;
                AND b.REVERSE_DATE is null
            UNION ALL
            SELECT /*+ INDEX(TU_FIN_TXN XIF123TU_FIN_TXN) */
                f.trade_date reBalanceDate
                FROM tu_fin_txn f, tu_acct a, tu_traunch t
                WHERE f.seq_acct_id = a.seq_acct_id
                AND a.traunch_id = t.traunch_id
                AND a.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
                AND a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
                AND f.fin_type = &apos;EXCHG&apos;
                AND f.fin_sub_type IN (&apos;R&apos;,&apos;T&apos;)
                AND (f.ctl_rec_stat IN (&apos;O&apos;,&apos;Q&apos;,&apos;P&apos;) or
                    (f.ctl_rec_stat = &apos;R&apos; and trunc(t.ASOF_DATE) &lt;= trunc(f.RUN_DATE)
                    and ((t.BACKEND_TYPE = &apos;TA2000&apos; and not exists
                        (select &apos;x&apos; from tdst_acct_txn h
                        where h.seq_acct_id = a.seq_acct_id
                        and h.seq_fin_txn_id = f.seq_fin_txn_id))
                        or
                        (t.BACKEND_TYPE = &apos;Omni&apos; and not exists
                        (select &apos;x&apos; from tu_acct_txn h
                        where h.uii_acct_id = a.uii_acct_id
                        and h.uii_acct_ext = a.uii_acct_ext
                        and h.seq_fin_txn_id = f.seq_fin_txn_id))
                        or
                        (t.BACKEND_TYPE = &apos;Phoenix&apos; and not exists
                        (select &apos;x&apos; from TU_BSD_ACCT_TXN h
                        where h.SEQ_ACCT_ID = a.SEQ_ACCT_ID
                        and h.seq_fin_txn_id = f.seq_fin_txn_id))
                        or
                        (t.BACKEND_TYPE = &apos;POWERAGENT&apos; and not exists
                        (select &apos;x&apos; from TENV_ACCT_TXN h
                        where h.SEQ_ACCT_ID = a.SEQ_ACCT_ID
                        and h.seq_fin_txn_id = f.seq_fin_txn_id))
                        or
                        (t.BACKEND_TYPE = &apos;JETT&apos; and not exists
                        (select &apos;x&apos; from TJET_ACCT_TXN h
                        where h.SEQ_ACCT_ID = a.SEQ_ACCT_ID
                        and h.seq_fin_txn_id = f.seq_fin_txn_id)))
                    )
                )
            ) order by reBalanceDate desc</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">CNT</stringProp>
          </JDBCSampler>

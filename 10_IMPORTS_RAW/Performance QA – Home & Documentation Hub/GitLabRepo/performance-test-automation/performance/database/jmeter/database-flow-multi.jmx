          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getOTLinkBySeqAcctId" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">   		select
   			link.SEQ_TOT_RECP_ACS_ACCT_ID &quot;seqRecipientLinkId&quot;,
   			link.SEQ_OT_PROGRAM_ID &quot;seqProgramId&quot;,
   			link.OT_RECIPIENT_NUMBER &quot;recipientNumber&quot;,
   			link.LINKED_SEQ_ACCT_ID &quot;linkedSeqAcctId&quot;,
            link.LINK_STATUS &quot;linkStatus&quot;,
   			link.SYNC_STATE &quot;syncState&quot;,
   			link.CSR_ID &quot;csrId&quot;,
   			program.PROGRAM_NUM &quot;programNum&quot;
   		from

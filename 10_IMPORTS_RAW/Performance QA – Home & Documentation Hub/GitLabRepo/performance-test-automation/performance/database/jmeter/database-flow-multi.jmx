        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getPdfConfirmsByMember" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        select cf.SEQ_CONFIRM_ID &quot;seqConfId&quot;, cf.cdate &quot;dateAndTime&quot;, cb.start_date &quot;date&quot;, cf.ctype &quot;confirmType&quot;,
        cf.change_id &quot;changeId&quot;, n.confirm_batch_id &quot;batchConfirmId&quot;, nvl(n.print_confirm_id,-1) &quot;printConfirmId&quot;,
        cf.style &quot;style&quot;, cb.STATE &quot;batchState&quot;,
        cb.insert_indicator &quot;insertIndicator&quot;,
        a.SEQ_ACCT_ID &quot;seqAccountId&quot;, a.uii_acct_id &quot;uiiAcctId&quot;, a.uii_acct_ext &quot;uiiAcctExt&quot;,
        a.UII_MEMBER_ID &quot;uiiMemberId&quot;, cb.confirm_vendor_batch_id &quot;confirmVendorBatchId&quot;
        from tu_confirm cf, tu_acct a, tu_notify n, tu_confirm_batch cb
        where a.seq_acct_id = cf.seq_acct_id
        and cf.seq_confirm_id = n.seq_confirm_id
        and n.confirm_batch_id = cb.confirm_batch_id
        and cf.ctype not in (&apos;OFR&apos;, &apos;FNY&apos;, &apos;GFC&apos;, &apos;DUM&apos;)
        and decode(cf.ctype, &apos;TAX&apos;, to_number(to_char(cb.start_date, &apos;YYYY&apos;))-1, to_number(to_char(cf.cdate, &apos;YYYY&apos;))) = &apos;2023&apos;
        and a.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;
        and cb.state = &apos;C&apos;
        and nvl(cf.CTL_REC_STAT, &apos;A&apos;)!=&apos;D&apos;
        order by cb.start_date desc, a.uii_acct_id, a.uii_acct_ext</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">SEQ_CONFIRM_ID,CDATE,STARTDATE,CONFIRM_TYPE,CHANGE_ID,CONFIRM_BATCH_ID,PRINT_CONFIRM_ID</stringProp>
        </JDBCSampler>
        <hashTree>

        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: get1099QsByMemberAndYear" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">    SELECT d.SEQ_1099Q_DATA_ID, d.TRAUNCH_ID, d.RETURN_IND, d.TAXEE_NAME_CTL, d.TIN_TYPE, d.TAXEE_TIN_E, d.TAXEE_TIN_CI, d.TAXEE_TIN_H, d.ACCOUNT_NUM, d.GROSS_DISTRIB, d.EARNINGS, d.CONTRIBUTIONS, d.TXN_DATE, d.TAX_YEAR, d.FORGN_COUNTRY_IND, d.TAXEE_FIRST_NAME, d.TAXEE_MIDDLE_INITIAL, d.TAXEE_LAST_NAME, d.TAXEE_SUFFIX, d.TAXEE_LINE_1, d.TAXEE_LINE_2, d.TAXEE_LINE_3, d.TAXEE_CITY, d.TAXEE_STATELABEL, d.TAXEE_ZIPCODE, d.TRUST_ROLLOVER_IND, d.DESIG_BENE, d.FEED_JOB_ID, d.CTL_INS_DTTM, d.CTL_UPD_DTTM, d.CTL_UPD_USER, d.CTL_REC_STAT, d.TXN_TYPE, d.SOURCE, d.ISSUED, c.code_id STATUS, d.CORRECTED, d.ORIGINAL_ID, d.SUPPRESS_CUST, d.SUPPRESS_FILING, d.FILING_DATE, d.CSR_ID, d.ISSUE_DATE, ROWNUM KEY, tcb.state, tcb.CONFIRM_BATCH_ID, d.SEQ_CONFIRM_ID,nvl(fj.processing_end, tcb.CTL_UPD_DTTM) as &quot;confirmBatchUpdateDate&quot;, tcb.CONFIRM_VENDOR_BATCH_ID 
    FROM tu_1099q_data d, tu_codes c, tu_confirm_batch tcb, tu_feed_job fj
    WHERE d.account_num in (select a.UII_ACCT_ID||&apos;-&apos;||a.uii_acct_ext from tu_acct a where a.UII_MEMBER_ID = &apos;${__V(APP_MEMBER_ID_1)}&apos;  )
    AND tax_year = &apos;2024&apos;
    AND d.status = c.seq_code_id
    AND d.confirm_batch_id = tcb.confirm_batch_id(+)
    AND tcb.PROMOTE_FEED_JOB_ID = fj.FEED_JOB_ID(+)
    ORDER BY seq_1099q_data_id DESC</stringProp>

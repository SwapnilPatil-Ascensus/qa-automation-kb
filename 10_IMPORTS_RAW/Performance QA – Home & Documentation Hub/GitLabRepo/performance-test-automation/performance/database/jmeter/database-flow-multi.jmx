          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getPendingReversals" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select
            r.SEQ_REV_TXN_ID as &quot;seqRevTxnId&quot;,
            r.SEQ_ACCT_ID as &quot;seqAcctId&quot;,
            r.SEQ_TXN_ID as &quot;seqTxnId&quot;,
            r.SEQ_FIN_TXN_ID as &quot;seqFinTxnId&quot;,
            r.txn_code as &quot;txnCode&quot;,
            c.code_id as &quot;stepNum&quot;,
            r.SEND_DATE as &quot;sendDate&quot;,
            r.FILE_ID as &quot;fileId&quot;,
            r.VOUCHER_NUM as &quot;voucherNumber&quot;,
            r.CSR_ID_ENTER as &quot;csrIdEnter&quot;,
            r.CSR_ENTER_DATE as &quot;csrEnterDate&quot;,
            r.CSR_ID_REJECT as &quot;csrIdReject&quot;,
            r.CSR_REJECT_DATE as &quot;csrRejectDate&quot;,
            r.CSR_ID_APPROVE as &quot;csrIdApprove&quot;,
            r.CSR_APPROVE_DATE as &quot;csrApproveDate&quot;,
            r.FEED_JOB_ID as &quot;feedJobId&quot;,
            r.CHANGE_ID as &quot;changeId&quot;,
            r.CTL_REC_STAT as &quot;ctlRecStat&quot;,
            a.uii_acct_id as &quot;uiiAcctId&quot;,
            a.uii_acct_ext as &quot;uiiAcctExt&quot;,
            c2.SEQ_CODE_ID as &quot;reasonCode.seqCodeId&quot;,
            c2.CODE_ID as &quot;reasonCode.codeId&quot;,
            c2.DESCRIPTION as &quot;reasonCode.desc&quot;,
            c2.TYPE as &quot;reasonCode.type&quot;,
            r.REBOOK as &quot;rebook&quot;,
            r.PARTNER_TXN_REF_ID as &quot;partnerTxnRefId&quot;,
            r.PARTNER_TXN_GROUP_ID as &quot;partnerTxnGroupId&quot;
        from TU_REV_TXN r, tu_codes c, tu_acct a, tu_codes c2
        WHERE r.step_num = c.seq_code_id(+)
        and r.DST_ASOF_REASON_CODE = c2.SEQ_CODE_ID(+)
        and r.SEQ_ACCT_ID = a.SEQ_ACCT_ID
        and a.uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos; 
        and a.uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos; 
        and (r.ctl_rec_stat in (&apos;O&apos;,&apos;P&apos;)
        or (r.CTL_REC_STAT = &apos;R&apos;
        and trunc(r.SEND_DATE) = trunc(sysdate)))
        and (exists
        (select &apos;x&apos; from
        tu_acct_txn h
        where h.seq_fin_txn_id = r.SEQ_FIN_TXN_ID
        and h.uii_acct_id = a.uii_acct_id
        and h.uii_acct_ext = a.UII_ACCT_EXT)
        or
        exists
        (select &apos;x&apos; from
        tdst_acct_txn dh
        where dh.seq_fin_txn_id = r.SEQ_FIN_TXN_ID
        and dh.seq_acct_id = a.SEQ_ACCT_ID)
        or
        exists
        (select &apos;x&apos; from
        tenv_acct_txn eh
        where eh.seq_fin_txn_id = r.SEQ_FIN_TXN_ID
        and eh.seq_acct_id = a.SEQ_ACCT_ID)
        or
        exists
        (select &apos;x&apos; from
        tenv_acct_txn eh
        where eh.seq_env_acct_txn_id = r.SEQ_TXN_ID
        and eh.seq_acct_id = a.SEQ_ACCT_ID)
        or
        exists
        (select &apos;x&apos; from
        tjet_acct_txn eh
        where eh.seq_fin_txn_id = r.SEQ_FIN_TXN_ID
        and eh.seq_acct_id = a.SEQ_ACCT_ID)
        or
        exists
        (select &apos;x&apos; from
        tjet_acct_txn eh
        where eh.seq_tjet_acct_txn_id = r.SEQ_TXN_ID
        and eh.seq_acct_id = a.SEQ_ACCT_ID)
        )</stringProp>

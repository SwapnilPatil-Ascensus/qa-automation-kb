        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getLastLoginForMember" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        select
    			created
    	from (select
    				login_id, created, RANK() OVER (ORDER by created desc) dttm_rank
    			from
    				TA_SESSION
    			where
    				login_id = &apos;${__V(LOGIN_ID_1)}&apos;  and csr_id is null )
    	where
    			dttm_rank = 2</stringProp>

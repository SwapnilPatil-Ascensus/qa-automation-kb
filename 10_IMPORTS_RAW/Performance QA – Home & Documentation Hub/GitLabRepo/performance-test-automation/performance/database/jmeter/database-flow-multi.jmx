          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: retrieveSingleBranch" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        SELECT b.seq_branch_id,
            b.seq_dealer_id,
            b.branch_name,
            b.rk_ext_id,
            trcd.code_id AS territory_id,
            b.phone_number,
            a.seq_address_id,
            a.addline1,
            a.addline2,
            a.addline3,
            a.addline4,
            a.city,
            a.state,
            a.zipcode,
            c.code_id AS address_type,
            b.all_accts_feed_flag,
            b.orion_feed_flag,
            b.ctl_rec_stat,
            b.jaccomo_feed_flag,
            svrCd.code_id &quot;suppressValidReasonCodeId&quot;
        FROM tu_branch b, tu_address a, tu_codes c, tu_codes trcd, tu_codes svrCd
        WHERE seq_branch_id = &apos;${__V(SEQ_BRANCH_ID_1)}&apos;
        AND b.seq_address_id = a.seq_address_id(+)
        AND a.address_type = c.seq_code_id(+)
        AND b.territory_id = trcd.seq_code_id(+)
        AND trcd.type(+) = &apos;JPM_TERRITORY_CODE&apos;
        and b.suppress_validation_reason = svrCd.seq_code_id(+)</stringProp>

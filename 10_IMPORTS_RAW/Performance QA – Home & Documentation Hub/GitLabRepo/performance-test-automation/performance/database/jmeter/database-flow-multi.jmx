          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getVideoStatementEligibility" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">          SELECT NVL (COUNT (*), 0)
          FROM TU_ACCT A, TU_VIDEO_STMT_ELIGIBLE SE
          WHERE A.SEQ_ACCT_ID = SE.SEQ_ACCT_ID
          AND SE.IS_ELIGIBLE = &apos;Y&apos;
          AND SE.CTL_REC_STAT = &apos;A&apos;
          AND A.UII_ACCT_ID = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
          AND UII_ACCT_EXT = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
         AND EXISTS
               (SELECT &apos;1&apos;
                  FROM tu_confirm c, tu_notify n, TU_CONFIRM_BATCH cb
                 WHERE c.seq_acct_id = a.seq_acct_id
                       AND n.SEQ_CONFIRM_ID = c.SEQ_CONFIRM_ID
                       AND c.ctype = &apos;STM&apos;
                       AND cb.CONFIRM_BATCH_ID = n.CONFIRM_BATCH_ID                       
                       AND cb.state = &apos;C&apos;
                       AND cb.promote_feed_job_id is not null
                       AND c.cdate = (select max(cdate) from tu_confirm where seq_acct_id = a.seq_acct_id and ctype= &apos;STM&apos;))</stringProp>

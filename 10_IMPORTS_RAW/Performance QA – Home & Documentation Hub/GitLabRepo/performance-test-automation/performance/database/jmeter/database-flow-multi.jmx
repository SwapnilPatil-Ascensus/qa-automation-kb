          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAuthorizedAgent" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">SELECT I.SEQ_PERSON_ID,I.SEQ_ACCT_ID,
P.DOB,
P.TITLE,
P.FIRST_NAME,
P.MIDDLE_INITIAL,
P.LAST_NAME,
P.SUFFIX,
P.ML_ADDLINE1,
P.ML_ADDLINE2,
P.ML_ADDLINE3,
P.ML_CITY,
 P.ML_ZIPCODE ,P.ML_STATELABEL ,P.IS_FOREIGN_ADDRESS,
P.SSN_E,
P.SSN_CI,
 I.STATUS,
I.ACCESS_LEVEL,
P.WORK_PHONE,
P.HOME_PHONE,
P.CTL_INS_DTTM,
I.GSP_PIN,
 (SELECT AA_TRANS_LEVEL FROM TU_MEMBER WHERE UII_MEMBER_ID = (SELECT UII_MEMBER_ID FROM TU_ACCT WHERE SEQ_ACCT_ID=I.SEQ_ACCT_ID)) TRANS_LEVEL,
 (select REL_DESC from TU_RELATIONSHIP where SEQ_REL_ID = I.SEQ_REL_ID) AUTHORIZATION_TYPE,
 (select REL_DESC from TU_RELATIONSHIP where SEQ_REL_ID = I.RELATIONSHIP_ID) RELATIONSHIP_ID,
 P.CTL_UPD_DTTM,
P.SYNC_STATE,
P.CHANGE_ID,
I.SYNC_STATE,
I.EFFECTIVE_DATE,
I.EXPIRATION_DATE,
I.STMT_COPIES_FLAG,
I.STOP_MAIL,
(select DESCRIPTION from TU_CODES where SEQ_CODE_ID = P.AI_TYPE_CODE) AI_TYPE_CODE from TU_AUTHORIZED_AGENT I,
TU_PERSON P  where P.SEQ_PERSON_ID = I.SEQ_PERSON_ID 
and ( I.status != &apos;X&apos; or I.status is null ) 
and P.CTL_REC_STAT != &apos;X&apos; 
and  I.SEQ_ACCT_ID = (select seq_acct_id from tu_acct where uii_acct_id = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
and uii_acct_ext = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos; ) order by ctl_ins_dttm desc</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>

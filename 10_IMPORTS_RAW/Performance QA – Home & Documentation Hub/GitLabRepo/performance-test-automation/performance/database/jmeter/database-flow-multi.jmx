          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: retrieveSingleDealerByTraunch" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        SELECT
            d.seq_dealer_id,
            d.dealer_name,
            d.rk_ext_id,
            trcd.code_id AS territory_id,
            dmp.CODE_ID as mailing_pref,
            a.seq_address_id,
            a.addline1,
            a.addline2,
            a.addline3,
            a.addline4,
            a.city,
            a.state,
            a.zipcode,
            c.code_id AS address_type,
            d.dtype,
            d.house_dealer,
            d.csr_id,
            d.portfolio_download_flag,
            d.albridge_feed_flag,
            d.all_accts_feed_flag,
            d.orion_feed_flag,
            d.jaccomo_feed_flag,
            d.ctl_rec_stat,
            d.crd_number,
            d.REP_ACCESS_READONLY,
            svrCd.code_id &quot;suppressValidReasonCodeId&quot;,
            d.is_clearing_firm
        FROM
            tu_dealer d, tu_address a, tu_codes c, tu_codes trcd, tu_codes svrCd, TU_DEALER_PLAN_DETAILS dpd, tu_codes dmp
        WHERE
            d.seq_dealer_id = &apos;${__V(SEQ_DEALER_ID_1)}&apos;
            AND d.seq_address_id = a.seq_address_id(+)
            AND a.address_type = c.seq_code_id(+)
            AND dpd.MAILING_PREF = dmp.seq_code_id (+)
            AND d.territory_id = trcd.seq_code_id(+)
            AND trcd.type(+) = &apos;JPM_TERRITORY_CODE&apos;
            and d.suppress_validation_reason = svrCd.seq_code_id(+)
            AND D.SEQ_DEALER_ID = DPD.SEQ_DEALER_ID
            AND dpd.traunch_id = &apos;${__V(A_TRAUNCH_ID_${count})}&apos;</stringProp>

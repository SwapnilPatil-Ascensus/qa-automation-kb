        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getAccountListByMemberId" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">            SELECT
                a.seq_acct_id &quot;oraid&quot;,
                a.traunch_id &quot;plannum&quot;,
                a.uii_acct_id &quot;prefix&quot;,
                a.uii_acct_ext &quot;ext&quot;,
                a.acct_state &quot;acctState&quot;,
                a.bd_accepted &quot;bdAccepted&quot;,
                a.enroll_status &quot;enrollStatus&quot;,
                a.enroll_method &quot;enrollMethod&quot;,
                a.reg_type &quot;regType&quot;,
                a.seq_sec_owner_id &quot;secOwnerOraid&quot;,
                a.seq_able_resp_indiv_id &quot;seqAbleRespIndivId&quot;,
                a.seq_avatar_image_id &quot;avatarImageId&quot;,
                custodianCodes.code_id &quot;ableCustodianType&quot;,
                a.uii_member_id &quot;uiiMemberId&quot;,
                b.first_name &quot;beneficiary.fname&quot;,
                b.middle_initial &quot;beneficiary.mname&quot;,
                b.last_name &quot;beneficiary.lname&quot;,
                b.suffix &quot;beneficiary.suffix&quot;,
                b.gender &quot;beneficiary.gender&quot;,
                p.title &quot;owner.title&quot;,
                p.first_name &quot;owner.fname&quot;,
                p.middle_initial &quot;owner.minitial&quot;,
                p.last_name &quot;owner.lname&quot;,
                p.suffix &quot;owner.suffix&quot;,
                p.gender &quot;owner.gender&quot;,
                p.home_ph_type &quot;owner.homePhType&quot;,
                p.work_ph_type &quot;owner.workPhType&quot;,
                t.branding &quot;branding&quot;,
                ra.bin &quot;acctBin&quot;,
                b.dob &quot;beneficiary.dob&quot;,
                b.state_of_residence &quot;beneficiary.stateOfResidence&quot;
            FROM
                tu_acct a, tu_bene b, tu_person p, tu_traunch t, tu_rep_acct ra, tu_codes custodianCodes
            WHERE
                a.uii_member_id = &apos;${__V(APP_MEMBER_ID_1)}&apos;
                and a.seq_bene_id = b.seq_bene_id
                and a.seq_part_id = p.seq_person_id
                and t.traunch_id = a.traunch_id
                and a.seq_acct_id = ra.seq_acct_id(+)
                and a.able_custodian_type = custodianCodes.seq_code_id(+)
                and nvl(ra.ctl_rec_stat(+), &apos;A&apos;) = &apos;A&apos;
                and nvl(enroll_status, &apos;A&apos;) != &apos;R&apos;
            ORDER BY
                a.seq_acct_id</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">A_SEQ_ACCT_ID,A_TRAUNCH_ID,A_UII_ACCT_ID,A_UII_ACCT_EXT</stringProp>
        </JDBCSampler>

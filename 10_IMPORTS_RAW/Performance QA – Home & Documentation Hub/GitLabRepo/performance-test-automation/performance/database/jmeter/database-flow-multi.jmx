          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getToAcctPendingTransactions" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        SELECT /*+ NO_INDEX(TXN FIN_TXN_IDX01) */
        TXN.SEQ_FIN_TXN_ID,TXN.SEQ_ACCT_ID,TXN.CSR_ID,TXN.TRADE_DATE,TXN.RUN_DATE,
        TXN.CTL_REC_STAT,INS.TO_SEQ_ACCT_ID,
        INS.SOURCE_CODE,INS.FUND_ID,INS.AMOUNT_TYPE,
        INS.PRINCIPAL_AMT,INS.EARN_AMT,INS.ACTIVITY,INS.FIN_TYPE,
        INS.SEQ_NUM,TXN.FIN_TYPE,TXN.FILE_ID,ACCT.UII_ACCT_ID,
        ACCT.UII_ACCT_EXT,TXN.VOUCHER_NUM,TXN.CHECK_NUM,
        TXN.TOTAL_AMT, TXN.RUN_DATE, TXN.CTL_REC_STAT, TXN.FIN_SUB_TYPE, TXN.TAX_YEAR, ACCT.UII_MEMBER_ID,
        TXN.CSR_ID_ENTER, TXN.CSR_ID_QA, TXN.CSR_ID_APPROVE, TXN.FEED_JOB_ID, TXN.LOAD_FEED_JOB_ID,
        TXN.CHANGE_ID, INS.TOTAL_AMT, TXN.GROSS_NET_IND, INS.SEQ_REP_ID, TXN.WAIVE_CDSC_FLAG, fund.class_type, fund.class_sub_type
        ,TR.BACKEND_TYPE
        FROM TU_FIN_TXN TXN, TU_FIN_INSTRUCTION INS, TU_ACCT ACCT, TU_TRAUNCH TR, TU_FUNDS FUND
        WHERE TXN.SEQ_FIN_TXN_ID=INS.SEQ_FIN_TXN_ID
        AND FUND.FUND_ID(+) = INS.FUND_ID
        AND INS.TO_SEQ_ACCT_ID = ACCT.SEQ_ACCT_ID
        AND ACCT.TRAUNCH_ID = TR.TRAUNCH_ID
        AND INS.TO_SEQ_ACCT_ID IS NOT NULL
        AND INS.TO_SEQ_ACCT_ID &lt;&gt; TXN.SEQ_ACCT_ID
        AND ACCT.UII_ACCT_ID = &apos;${__V(A_UII_ACCT_ID_${count})}&apos; 
        AND ACCT.UII_ACCT_EXT = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos; 
        AND ((TXN.CTL_REC_STAT IN (&apos;O&apos;,&apos;Q&apos;, &apos;S&apos;, &apos;P&apos;, &apos;M&apos;, &apos;E&apos;, &apos;I&apos;, &apos;B&apos;, &apos;D&apos;))
        OR
        ((tr.branding = &apos;ohio&apos; OR (tr.product_type=&apos;ABLE&apos; AND tr.branding != &apos;tnable&apos;)) AND txn.ctl_rec_stat = &apos;R&apos;)
        OR
        ((TXN.CTL_REC_STAT = &apos;R&apos;) AND (TRUNC(TR.ASOF_DATE)&lt;TRUNC(TXN.RUN_DATE)))
        )
        AND TXN.FIN_TYPE&lt;&gt;&apos;FINCONV&apos;
        AND nvl(txn.web_display,&apos;Y&apos;)=&apos;Y&apos;</stringProp>

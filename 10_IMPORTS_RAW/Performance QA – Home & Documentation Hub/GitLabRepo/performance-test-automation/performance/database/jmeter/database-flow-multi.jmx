        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getCs529TraunchData" enabled="true">
          <stringProp name="dataSource">oraclePool</stringProp>
          <stringProp name="query">        SELECT cd.code_id AS address_type,
           ta.address1,
           ta.address2,
           ta.address3,
           ta.address4,
           ta.city,
           ta.state tr_addr_state,
           ta.zipcode,
           t.*,
           uii_traunch.get_traunch_fees () tr_fee_coll,
           uii_traunch.get_traunch_relationships () tr_rel_coll
      FROM tu_traunch_address ta, tu_codes cd, tu_traunch t
     WHERE ta.address_type = cd.seq_code_id (+)
           AND t.traunch_id = ta.traunch_id (+)
           AND nvl(t.ctl_rec_stat, &apos;A&apos;) = &apos;A&apos;
           order by t.traunch_id
</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">CNT</stringProp>
        </JDBCSampler>

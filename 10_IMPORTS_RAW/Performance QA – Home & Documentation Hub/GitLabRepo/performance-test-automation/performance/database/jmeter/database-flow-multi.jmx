          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="SELECT: getUnCashedChecksByUiiAcctId" enabled="true">
            <stringProp name="dataSource">oraclePool</stringProp>
            <stringProp name="query">        select ck.SEQ_CHECK_ID &quot;checkID&quot;, ck.CHECK_NUM &quot;checkNumber&quot;, ck.CHECK_AMOUNT &quot;checkAmount&quot;,
        ck.CHECK_DATE &quot;checkDate&quot;, ck.PAYEE_NAME &quot;payeeName&quot;
        from tu_confirm cf, tu_notify nf, tu_confirm_batch cb, tu_check ck
        where cf.SEQ_CONFIRM_ID = nf.SEQ_CONFIRM_ID
        and nf.CONFIRM_BATCH_ID = cb.CONFIRM_BATCH_ID
        and cb.STATE in (&apos;A&apos;, &apos;C&apos;)
        and cf.CTYPE = &apos;UCK&apos;
        and nvl(cf.CTL_REC_STAT, &apos;A&apos;)!=&apos;D&apos;
        and ck.CHANGE_ID = cf.CHANGE_ID
        and ck.STATUS = (select uii_codes.get_code(&apos;I&apos;, &apos;DISB_ACCT_REC_STAT&apos;) from dual)
        and ck.ACCT_REF_NUM = &apos;${__V(A_UII_ACCT_ID_${count})}&apos; || &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;
        union
        select ck.SEQ_CHECK_ID &quot;checkID&quot;, ck.CHECK_NUM &quot;checkNumber&quot;, ck.CHECK_AMOUNT &quot;checkAmount&quot;,
        ck.CHECK_DATE &quot;checkDate&quot;, ck.PAYEE_NAME &quot;payeeName&quot;
        from tu_confirm cf, tu_notify nf, tu_confirm_batch cb, tu_check ck,
        tu_acct a, TU_DISBURSEMENT d, TU_DISBURSEMENT_CHECK dc
        where cf.SEQ_CONFIRM_ID = nf.SEQ_CONFIRM_ID
        and nf.CONFIRM_BATCH_ID = cb.CONFIRM_BATCH_ID
        and cb.STATE in (&apos;A&apos;, &apos;C&apos;)
        and cf.CTYPE = &apos;UCK&apos;
        and nvl(cf.CTL_REC_STAT, &apos;A&apos;)!=&apos;D&apos;
        and ck.CHANGE_ID = cf.CHANGE_ID
        and ck.STATUS = (select uii_codes.get_code(&apos;I&apos;, &apos;DISB_ACCT_REC_STAT&apos;) from dual)
        and cf.SEQ_ACCT_ID = a.SEQ_ACCT_ID
        and a.SEQ_ACCT_ID = d.SEQ_ACCT_ID
        and d.SEQ_DISBURSEMENT_ID = dc.SEQ_DISBURSEMENT_ID
        and dc.SEQ_CHECK_ID = ck.SEQ_CHECK_ID
        and a.UII_ACCT_ID = &apos;${__V(A_UII_ACCT_ID_${count})}&apos;
        and a.UII_ACCT_EXT = &apos;${__V(A_UII_ACCT_EXT_${count})}&apos;</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">SEQ_REP_ID</stringProp>
          </JDBCSampler>
          <hashTree>

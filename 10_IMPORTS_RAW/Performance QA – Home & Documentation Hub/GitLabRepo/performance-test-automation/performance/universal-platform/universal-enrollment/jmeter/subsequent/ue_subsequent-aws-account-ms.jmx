            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSON Extractor - User w/ Phone Update" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper;
import groovy.json.JsonBuilder;

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

def builder = new JsonBuilder(json)
builder.content.&apos;urn:ascensus:529:1.0:account&apos;.user.contacts.daytimePhone = &apos;+1&apos; + builder.content.&apos;urn:ascensus:529:1.0:account&apos;.user.contacts.daytimePhone
builder.content.&apos;urn:ascensus:529:1.0:account&apos;.user.contacts.eveningPhone = &apos;+1&apos; + builder.content.&apos;urn:ascensus:529:1.0:account&apos;.user.contacts.eveningPhone
builder.content = builder.content.&apos;urn:ascensus:529:1.0:account&apos;.user
builder.content.remove(&apos;lastModifiedDateTime&apos;)

vars.put(&quot;user&quot;, builder.toPrettyString())
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>

          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Set How You Heard Based on Plan">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def howyouheard = [&apos;dcdirect&apos;, &apos;nmdirect&apos;]
if (howyouheard.contains(vars.get(&apos;branding&apos;))) {
	vars.put(&apos;howyouheard&apos;, &apos;true&apos;);
}
else {
	vars.put(&apos;howyouheard&apos;, &apos;false&apos;);
}
</stringProp>

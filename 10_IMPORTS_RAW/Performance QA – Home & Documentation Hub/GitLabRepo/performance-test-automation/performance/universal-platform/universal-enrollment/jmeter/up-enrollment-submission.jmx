            &quot;fundId&quot;: &quot;${investFund1}&quot;,&#xd;
            &quot;allocationPercent&quot;: &quot;${investFundAlloc1}&quot;&#xd;
          },&#xd;
          {&#xd;
            &quot;fundId&quot;: &quot;${investFund2}&quot;,&#xd;

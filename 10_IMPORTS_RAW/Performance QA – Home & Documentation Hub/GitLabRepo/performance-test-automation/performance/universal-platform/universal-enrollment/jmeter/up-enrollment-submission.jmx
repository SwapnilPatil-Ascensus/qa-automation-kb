    <hashTree>
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Environment Setup - Local (QC4)" enabled="false">
        <collectionProp name="Arguments.arguments">
          <elementProp name="enrollment-host" elementType="Argument">
            <stringProp name="Argument.name">enrollment-host</stringProp>

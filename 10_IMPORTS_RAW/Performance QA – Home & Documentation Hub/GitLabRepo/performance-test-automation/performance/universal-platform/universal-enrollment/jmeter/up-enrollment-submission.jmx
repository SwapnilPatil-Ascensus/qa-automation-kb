        <boolProp name="CookieManager.controlledByThreadGroup">false</boolProp>
      </CookieManager>
      <hashTree/>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Enrollment - 1 Beneficiary By Bank + Recurring to 3 Funds">
        <stringProp name="TestPlan.comments">Login &gt; Snapshot &gt; Submit</stringProp>
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">startnextloop</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Enrollment Data Generator">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.jmeter.testelement.property.JMeterProperty;
import org.apache.jmeter.util.JMeterUtils;
import org.apache.jmeter.services.FileServer;
import org.apache.commons.lang3.RandomStringUtils;

TimeZone.setDefault(TimeZone.getTimeZone(&apos;UTC&apos;));
Random random = new Random();

////////////////////////////// ENROLLMENT //////////////////////////////////////////////////

vars.put(&quot;masterUuid&quot;, UUID.randomUUID().toString());

////////////////////////////// USER ////////////////////////////////////////////////////////

vars.put(&quot;userUuid&quot;, UUID.randomUUID().toString());

vars.put(&quot;userPrefix&quot;, &quot;Mr.&quot;);
vars.put(&quot;userFirst&quot;, &quot;John&quot;);
vars.put(&quot;userMiddle&quot;, &quot;P&quot;);
vars.put(&quot;userLast&quot;, &quot;Smith&quot;);
vars.put(&quot;userSuffix&quot;, &quot;Jr.&quot;);

vars.put(&quot;userDob&quot;, new Date().clearTime().minus(365 * 20).format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;));
vars.put(&quot;userSsn&quot;, String.format(&quot;%09d&quot;, ${__Random(100000000,999999999)}));

vars.put(&quot;userEmail&quot;, &quot;test&quot; + 	random.nextInt(999999999).toString() + &quot;@test.com&quot;);
vars.put(&quot;userHPhone&quot;, &quot;+1508&quot; + ((int)(Math.random() * 9000000) + 1000000).toString());
vars.put(&quot;userWPhone&quot;, &quot;+1508&quot; + ((int)(Math.random() * 9000000) + 1000000).toString());

vars.put(&quot;userPAdd1&quot;, random.nextInt(999).toString() + &quot; Main St&quot;);
vars.put(&quot;userPAdd2&quot;, &quot;Floor&quot; + random.nextInt(9).toString());
vars.put(&quot;userPAdd3&quot;, &quot;Suite&quot; + random.nextInt(999).toString());
vars.put(&quot;userMAdd1&quot;, random.nextInt(999).toString() + &quot; Main St&quot;);
vars.put(&quot;userMAdd2&quot;, &quot;Floor&quot; + random.nextInt(9).toString());
vars.put(&quot;userMAdd3&quot;, &quot;Suite&quot; + random.nextInt(999).toString());

vars.put(&quot;login&quot;, &quot;username&quot; + random.nextInt(999999999).toString());
vars.put(&quot;password&quot;, &quot;Test@123&quot;);

vars.put(&quot;id&quot;, RandomStringUtils.randomAlphanumeric(9));
vars.put(&quot;idExpire&quot;, new Date().clearTime().plus(365 * 2).format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;));
vars.put(&quot;idName&quot;, &quot;Johnson&quot;);


////////////////////////////// BENEFICIARY /////////////////////////////////////////////////

vars.put(&quot;beneUuid&quot;, UUID.randomUUID().toString());

vars.put(&quot;benePrefix&quot;, &quot;Ms.&quot;);
vars.put(&quot;beneFirst&quot;, &quot;Jill&quot;);
vars.put(&quot;beneMiddle&quot;, &quot;J&quot;);
vars.put(&quot;beneLast&quot;, &quot;Smithson&quot;);
vars.put(&quot;beneSuffix&quot;, &quot;II&quot;);

vars.put(&quot;beneDob&quot;, new Date().clearTime().minus(365 * 2).format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;));
vars.put(&quot;beneSsn&quot;, String.format(&quot;%09d&quot;, ${__Random(100000000,999999999)}));

vars.put(&quot;beneMAdd1&quot;, random.nextInt(999).toString() + &quot; Main St&quot;);
vars.put(&quot;beneMAdd2&quot;, &quot;Floor&quot; + random.nextInt(9).toString());
vars.put(&quot;beneMAdd3&quot;, &quot;Suite&quot; + random.nextInt(999).toString());

////////////////////////////// FUNDING /////////////////////////////////////////////////////

vars.put(&quot;fundingUuid1&quot;, UUID.randomUUID().toString());
vars.put(&quot;initialAmount&quot;, (random.nextInt(999) + 50).toString());
vars.put(&quot;initialStart&quot;, new Date().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSSZ&quot;));

vars.put(&quot;fundingUuid2&quot;, UUID.randomUUID().toString());
vars.put(&quot;recurringAmount&quot;, (random.nextInt(99) + 50).toString());
vars.put(&quot;recurringStart&quot;, new Date().clearTime().plus(7).format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;));
vars.put(&quot;annualAmount&quot;, (random.nextInt(99) + 10).toString());

////////////////////////////// BANK ////////////////////////////////////////////////////////

vars.put(&quot;bankFirst&quot;, &quot;Banker&quot;);
vars.put(&quot;bankLast&quot;, &quot;Owner&quot;);

vars.put(&quot;bankUuid&quot;, UUID.randomUUID().toString());
vars.put(&quot;bank&quot;, ((int)(Math.random() * 900000000) + 1000000000).toString());
vars.put(&quot;bankPhone&quot;, &quot;1508&quot; + ((int)(Math.random() * 9000000) + 1000000).toString());
vars.put(&quot;bankAdd1&quot;, random.nextInt(999).toString() + &quot; Main St&quot;);
vars.put(&quot;bankAdd2&quot;, &quot;Floor&quot; + random.nextInt(9).toString());

////////////////////////////// INVESTMENTS /////////////////////////////////////////////////

Integer allocation1 = ((int) (Math.random() * 35) + 5);
vars.put(&quot;investFundAlloc1&quot;, allocation1.toString());
Integer allocation2 = ((int) (Math.random() * 35) + 5);
vars.put(&quot;investFundAlloc2&quot;, allocation2.toString());
vars.put(&quot;investFundAlloc3&quot;, (100 - allocation1 - allocation2).toString());
</stringProp>
        </JSR223Sampler>

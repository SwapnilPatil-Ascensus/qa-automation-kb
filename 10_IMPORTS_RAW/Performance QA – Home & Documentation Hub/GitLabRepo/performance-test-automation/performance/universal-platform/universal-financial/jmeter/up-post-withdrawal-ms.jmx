            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Content-Type</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Authorization</stringProp>
                  <stringProp name="Header.value">Bearer ${access_token}</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Header Generator">
              <stringProp name="cacheKey">false</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import javax.crypto.Mac;
import javax.crypto.spec.SecretKeySpec;
import org.apache.jmeter.protocol.http.control.Header;
import org.apache.jmeter.protocol.http.util.Base64Encoder;

TimeZone.setDefault(TimeZone.getTimeZone(&apos;UTC&apos;));

// Set the request id (x-request-id)
uuid = UUID.randomUUID().toString();
sampler.getHeaderManager().removeHeaderNamed(&quot;x-request-id&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-request-id&quot;, uuid));

// Set the current datetime (x-request-datetime)
currentUTC = new Date().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss.SSS&apos;Z&apos;&quot;);
sampler.getHeaderManager().removeHeaderNamed(&quot;x-request-datetime&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-request-datetime&quot;, currentUTC));

// Set the json signature (x-signature)
message = sampler.getArguments().getArgument(0).getValue();
Mac mac = Mac.getInstance(&quot;HmacSHA256&quot;);
SecretKeySpec secretKeySpec = new SecretKeySpec(vars.get(&quot;signing_key&quot;).decodeBase64(), &quot;HmacSHA256&quot;);
mac.init(secretKeySpec);
signature = mac.doFinal(message.getBytes()).encodeBase64().toString();
sampler.getHeaderManager().removeHeaderNamed(&quot;x-signature&quot;);
sampler.getHeaderManager().add(new Header(&quot;x-signature&quot;, signature));
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
            <hashTree/>

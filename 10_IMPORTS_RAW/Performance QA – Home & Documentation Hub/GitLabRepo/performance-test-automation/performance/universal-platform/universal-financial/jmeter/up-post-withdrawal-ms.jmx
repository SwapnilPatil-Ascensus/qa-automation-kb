        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Withdrawal Data Generator" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.jmeter.testelement.property.JMeterProperty;
import org.apache.jmeter.util.JMeterUtils;
import org.apache.jmeter.services.FileServer;
import org.apache.commons.lang3.RandomStringUtils;

TimeZone.setDefault(TimeZone.getTimeZone(&apos;UTC&apos;));
Random random = new Random();

////////////////////////////// WITHDRAWAL //////////////////////////////////////////////////

vars.put(&quot;uuid_withdrawal&quot;, UUID.randomUUID().toString());

////////////////////////////// INSTRUCTION /////////////////////////////////////////////////

vars.put(&quot;uuid_instruction&quot;, UUID.randomUUID().toString());

////////////////////////////// DISBURSEMENT ////////////////////////////////////////////////

vars.put(&quot;uuid_disbursement&quot;, UUID.randomUUID().toString());

////////////////////////////// BANK ////////////////////////////////////////////////////////

vars.put(&quot;uuid_bank&quot;, UUID.randomUUID().toString());

////////////////////////////// BANK ////////////////////////////////////////////////////////

vars.put(&quot;uuid_ach&quot;, UUID.randomUUID().toString());
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Hide Sampler From Reports" enabled="true">

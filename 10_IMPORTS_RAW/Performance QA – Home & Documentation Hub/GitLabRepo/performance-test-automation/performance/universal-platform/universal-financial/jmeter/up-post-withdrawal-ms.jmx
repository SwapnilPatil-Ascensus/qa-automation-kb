          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">String request = &quot;Authentication - Get Client Token&quot;;
def idpEnabled = vars.get(&quot;idp-enabled&quot;) ?: &apos;false&apos;;
if (idpEnabled.toBoolean()) {
    request = &quot;Authentication - Get PKCE Token&quot;;
}

vars.put(&quot;idp&quot;, request);
</stringProp>
        </JSR223Sampler>

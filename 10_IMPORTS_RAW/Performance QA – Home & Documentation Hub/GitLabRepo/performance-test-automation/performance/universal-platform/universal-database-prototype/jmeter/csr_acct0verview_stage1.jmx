        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler Decrypt">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import javax.crypto.Cipher
import javax.crypto.KeyGenerator
import javax.crypto.SecretKey
import javax.crypto.spec.IvParameterSpec 
import javax.crypto.spec.SecretKeySpec 
import java.util.Base64
import java.nio.file.Files
import java.nio.file.Paths

// Generate a 16-byte AES key
def generateKey() {
    KeyGenerator keyGen = KeyGenerator.getInstance(&quot;AES&quot;)
    keyGen.init(128) // 128-bit key (16 bytes)
    return keyGen.generateKey()
    
}

// Encrypt data
def encrypt(SecretKey key, String data) {
    Cipher cipher = Cipher.getInstance(&quot;AES/CBC/PKCS5Padding&quot;)
    byte[] iv = new byte[16] // Initialization vector (16 bytes)
    IvParameterSpec ivSpec = new IvParameterSpec(iv)
    cipher.init(Cipher.ENCRYPT_MODE, key, ivSpec)
    byte[] encryptedData = cipher.doFinal(data.getBytes(&quot;UTF-8&quot;))
    return Base64.encoder.encodeToString(encryptedData)
}

// Decrypt data
def decrypt(SecretKey key, String encryptedData) {
    Cipher cipher = Cipher.getInstance(&quot;AES/CBC/PKCS5Padding&quot;)
    byte[] iv = new byte[16] // Initialization vector (16 bytes)
    IvParameterSpec ivSpec = new IvParameterSpec(iv)
    cipher.init(Cipher.DECRYPT_MODE, key, ivSpec)
    byte[] decodedData = Base64.decoder.decode(encryptedData)
    byte[] decryptedData = cipher.doFinal(decodedData)
    return new String(decryptedData, &quot;UTF-8&quot;) }
// Load the Base64-encoded key from a file
def loadKeyFromFile(String filePath) {
    String encodedKey = new
    String(Files.readAllBytes(Paths.get(filePath)), &quot;UTF-8&quot;)
    byte[] decodedKey = Base64.getDecoder().decode(encodedKey)
    return new SecretKeySpec(decodedKey, 0, decodedKey.length, &quot;AES&quot;) }

// Main execution
String filePath = &quot;secretKeyStage.txt&quot;

// Load the key from the file
SecretKey key = loadKeyFromFile(filePath)
//log.info(&quot;Key loaded from file:&quot; + key)
log.info(&quot;Key loaded from file:&quot; + key.getEncoded().encodeHex())

String uid = &quot;&quot;
String pwd = &quot;&quot;
String encryptedUid = vars.get(&quot;userName&quot;)
String encryptedPwd = vars.get(&quot;password&quot;)
// Encrypt UID and password
//String encryptedUid = encrypt(key, uid)
//String encryptedPwd = encrypt(key, pwd)

//log.info(&quot;Encrypted UID:&quot;+ encryptedUid)
//log.info(&quot;Encrypted PWD:&quot;+ encryptedPwd)


// Decrypt UID and password csrUID,csrPWD
String decryptedUid = decrypt(key, encryptedUid) 
String decryptedPwd = decrypt(key, encryptedPwd)
vars.put(&quot;csrUID&quot;,decryptedUid)
vars.put(&quot;csrPWD&quot;,decryptedPwd)
//log.info(&quot;Decncrypted PWD:&quot; + vars.get(&quot;userName&quot;))
//log.info(&quot;Decncrypted PWD:&quot; + vars.get(&quot;password&quot;))

</stringProp>
        </JSR223Sampler>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Decrypt Credentials" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import javax.crypto.Cipher
import javax.crypto.KeyGenerator
import javax.crypto.SecretKey
import javax.crypto.spec.IvParameterSpec 
import javax.crypto.spec.SecretKeySpec 
import java.util.Base64
import java.nio.file.Files
import java.nio.file.Paths

// Generate a 16-byte AES key
def generateKey() {
    KeyGenerator keyGen = KeyGenerator.getInstance(&quot;AES&quot;)
    keyGen.init(128) // 128-bit key (16 bytes)
    return keyGen.generateKey()
}

// Decrypt data
def decrypt(SecretKey key, String encryptedData) {
    Cipher cipher = Cipher.getInstance(&quot;AES/CBC/PKCS5Padding&quot;)
    byte[] iv = new byte[16] // Initialization vector (16 bytes)
    IvParameterSpec ivSpec = new IvParameterSpec(iv)
    cipher.init(Cipher.DECRYPT_MODE, key, ivSpec)
    byte[] decodedData = Base64.decoder.decode(encryptedData)
    byte[] decryptedData = cipher.doFinal(decodedData)
    return new String(decryptedData, &quot;UTF-8&quot;)
}
    
// Load the Base64-encoded key from a file
def loadKeyFromFile(String filePath) {
    String encodedKey = vars.get(&quot;keyPathByJmx&quot;).equals(&quot;true&quot;) ? new String(Files.readAllBytes(Paths.get(vars.get(&quot;keyPath&quot;) + File.separator + filePath)), &quot;UTF-8&quot;) : new String(Files.readAllBytes(Paths.get(filePath)), &quot;UTF-8&quot;)
    byte[] decodedKey = Base64.getDecoder().decode(encodedKey)
    return new SecretKeySpec(decodedKey, 0, decodedKey.length, &quot;AES&quot;) 
}

// Main execution
String filePath = vars.get(&quot;keyFile&quot;)

// Load the key from the file
SecretKey key = loadKeyFromFile(filePath)

// Decrypt client secret
String encryptedClient = vars.get(&quot;clientSecretEncrypt&quot;)
String decryptedClient = decrypt(key, encryptedClient)
vars.put(&quot;clientSecret&quot;, decryptedClient)
//log.info(&quot;Decrypted: &quot; + vars.get(&quot;clientSecret&quot;))

// Decrypt private key
String encryptedKey = vars.get(&quot;privateKeyEncrypt&quot;)
String decryptedKey = decrypt(key, encryptedKey)
vars.put(&quot;privateKey&quot;, decryptedKey)
//log.info(&quot;Decrypted: &quot; + vars.get(&quot;privateKey&quot;))

// Decrypt portal username
String encryptedUsername = vars.get(&quot;userUsernameEncrypt&quot;)
String decryptedUsername = decrypt(key, encryptedUsername)
vars.put(&quot;userUsername&quot;, decryptedUsername)
//log.info(&quot;Decrypted: &quot; + vars.get(&quot;userUsername&quot;))
log.info(&quot;========================Kumar=================&quot; + vars.get(&quot;userUsername&quot;));

// Decrypt portal password
String encryptedPassword = vars.get(&quot;userPasswordEncrypt&quot;)
String decryptedPassword = decrypt(key, encryptedPassword)
String credentials = decryptedPassword.getBytes().encodeBase64().toString();
vars.put(&quot;userPassword&quot;, credentials);
//log.info(&quot;Decrypted: &quot; + vars.get(&quot;userPassword&quot;))
log.info(&quot;========================Kumar=================&quot; + vars.get(&quot;userPassword&quot;));

</stringProp>
        </JSR223Sampler>

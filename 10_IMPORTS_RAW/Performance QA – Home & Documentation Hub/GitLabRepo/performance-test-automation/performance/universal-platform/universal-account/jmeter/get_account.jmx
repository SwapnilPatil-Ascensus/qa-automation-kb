          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate JWT Token">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import io.jsonwebtoken.JwtBuilder;
import io.jsonwebtoken.Jwts;
import java.security.Key;
import javax.crypto.spec.SecretKeySpec;

Key signingKey = new SecretKeySpec(vars.get(&quot;clientSecret&quot;).getBytes(), &quot;HmacSHA256&quot;);

        // Generate the JWT
        String jwt = Jwts.builder()
                .setIssuer(vars.get(&quot;clientId&quot;)) // Set the issuer (iss)
                .setSubject(vars.get(&quot;clientId&quot;)) // Set the subject (sub)
                .setAudience(&quot;https://agsup-auth-server-stage1.gs.ascensus.com/services/oauth2&quot;) // Set the audience (aud)
                .setExpiration(new Date(System.currentTimeMillis() + 86400000)) // Set expiration (exp)
                 .signWith(signingKey)
                .compact();

          //  log.info(&quot;-----------------pramod jwt1------------&quot; + jwt);
              vars.put(&quot;jwtToken&quot;, jwt)


  //  log.info(&quot;--------------------------------------------------&quot;+  vars.get(&quot;bearerToken&quot;));
     
</stringProp>
          </JSR223PreProcessor>

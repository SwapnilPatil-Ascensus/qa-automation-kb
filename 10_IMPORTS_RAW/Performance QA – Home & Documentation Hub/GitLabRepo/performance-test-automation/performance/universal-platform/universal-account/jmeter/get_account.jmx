    &quot;schema&quot;: &quot;urn:ascensus:529:1.0:account&quot;,&#xd;
	&quot;urn:ascensus:529:1.0:account&quot;: {&#xd;
		 &quot;rootAccountNumber&quot;: &quot;${acctnum}&quot;&#xd;

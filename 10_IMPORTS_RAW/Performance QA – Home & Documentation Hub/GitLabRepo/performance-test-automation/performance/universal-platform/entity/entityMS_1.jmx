                  </elementProp>
                  <elementProp name="" elementType="Header">
                    <stringProp name="Header.name">X-API-Key</stringProp>
                    <stringProp name="Header.value">00000000-0000-0000-0000-000000000000</stringProp>
                  </elementProp>
                  <elementProp name="" elementType="Header">
                    <stringProp name="Header.name">x-signature</stringProp>
                    <stringProp name="Header.value">t</stringProp>
                  </elementProp>
                  <elementProp name="" elementType="Header">
                    <stringProp name="Header.name">x-request-datetime</stringProp>
                    <stringProp name="Header.value">01-01-2014</stringProp>
                  </elementProp>
                  <elementProp name="" elementType="Header">

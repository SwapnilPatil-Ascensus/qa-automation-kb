        <hashTree/>
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Encrypt CSV Credentials"/>
        <hashTree>
          <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="Account Data Load">
            <stringProp name="delimiter">,</stringProp>
            <stringProp name="fileEncoding"></stringProp>
            <stringProp name="filename">credentials.csv</stringProp>
            <boolProp name="ignoreFirstLine">true</boolProp>
            <boolProp name="quotedData">false</boolProp>
            <boolProp name="recycle">true</boolProp>
            <stringProp name="shareMode">shareMode.all</stringProp>
            <boolProp name="stopThread">false</boolProp>
            <stringProp name="variableNames">plan-prefix,username,password,account</stringProp>
          </CSVDataSet>
          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encrypt Credentials">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.io.File;
import org.apache.jmeter.services.FileServer;
import java.io.FileWriter;
import java.io.PrintWriter;
import java.util.Arrays;
import java.io.Writer;
import java.nio.file.Paths;

import javax.crypto.Cipher
import javax.crypto.KeyGenerator
import javax.crypto.SecretKey
import javax.crypto.spec.IvParameterSpec 
import javax.crypto.spec.SecretKeySpec 
import java.util.Base64
import java.nio.file.Files
import java.nio.file.Paths

// Encrypt data
def encrypt(SecretKey key, String data) {
    Cipher cipher = Cipher.getInstance(&quot;AES/CBC/PKCS5Padding&quot;)
    byte[] iv = new byte[16] // Initialization vector (16 bytes)
    IvParameterSpec ivSpec = new IvParameterSpec(iv)
    cipher.init(Cipher.ENCRYPT_MODE, key, ivSpec)
    byte[] encryptedData = cipher.doFinal(data.getBytes(&quot;UTF-8&quot;))
    return Base64.encoder.encodeToString(encryptedData)
}

// Load the Base64-encoded key from a file
def loadKeyFromFile(String filePath) {
	String key = vars.get(&quot;keyPathByJmx&quot;);
	String encodedKey;

	// Use JMX path for key file
	if (key.equals(&quot;true&quot;)) {
		encodedKey = new String(Files.readAllBytes(Paths.get(vars.get(&quot;keyPath&quot;) + File.separator + filePath)), &quot;UTF-8&quot;);
	}

	// Use JMeter path for key file
	else if (key.equals(&quot;false&quot;)) {
		encodedKey = new String(Files.readAllBytes(Paths.get(filePath)), &quot;UTF-8&quot;);
	}

	// Use path relative to JMX path for key file
	else {
		encodedKey = new String(Files.readAllBytes(Paths.get(vars.get(&quot;keyPath&quot;) + File.separator + key + File.separator + filePath)), &quot;UTF-8&quot;);
	}
    byte[] decodedKey = Base64.getDecoder().decode(encodedKey)
    return new SecretKeySpec(decodedKey, 0, decodedKey.length, &quot;AES&quot;) 
}

// Main execution
String filePath = vars.get(&quot;keyFile&quot;)

// Load the key from the file
SecretKey key = loadKeyFromFile(filePath)

File file = Paths.get(vars.get(&quot;keyPath&quot;) + File.separator + &quot;encrypted.csv&quot;).toFile();
FileWriter fstream = new FileWriter(file, true);

BufferedWriter out = new BufferedWriter(fstream);
out.write(vars.get(&quot;plan-prefix&quot;) + &quot;,&quot;);
out.write(encrypt(key, vars.get(&quot;username&quot;)) + &quot;,&quot;);
out.write(encrypt(key, vars.get(&quot;password&quot;)) + &quot;,&quot;);
out.write(vars.get(&quot;account&quot;) + &quot;\n&quot;);

out.close();
fstream.close();
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Encrypt Value"/>
        <hashTree>
          <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments">
              <elementProp name="unencryptedValue" elementType="Argument">
                <stringProp name="Argument.name">unencryptedValue</stringProp>
                <stringProp name="Argument.value"></stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </Arguments>
          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Encrypt Credentials">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.io.File;
import org.apache.jmeter.services.FileServer;
import java.io.FileWriter;
import java.io.PrintWriter;
import java.util.Arrays;
import java.io.Writer;
import java.nio.file.Paths;

import javax.crypto.Cipher
import javax.crypto.KeyGenerator
import javax.crypto.SecretKey
import javax.crypto.spec.IvParameterSpec 
import javax.crypto.spec.SecretKeySpec 
import java.util.Base64
import java.nio.file.Files
import java.nio.file.Paths

// Encrypt data
def encrypt(SecretKey key, String data) {
    Cipher cipher = Cipher.getInstance(&quot;AES/CBC/PKCS5Padding&quot;)
    byte[] iv = new byte[16] // Initialization vector (16 bytes)
    IvParameterSpec ivSpec = new IvParameterSpec(iv)
    cipher.init(Cipher.ENCRYPT_MODE, key, ivSpec)
    byte[] encryptedData = cipher.doFinal(data.getBytes(&quot;UTF-8&quot;))
    return Base64.encoder.encodeToString(encryptedData)
}

// Load the Base64-encoded key from a file
def loadKeyFromFile(String filePath) {
	String key = vars.get(&quot;keyPathByJmx&quot;);
	String encodedKey;

	// Use JMX path for key file
	if (key.equals(&quot;true&quot;)) {
		encodedKey = new String(Files.readAllBytes(Paths.get(vars.get(&quot;keyPath&quot;) + File.separator + filePath)), &quot;UTF-8&quot;);
	}

	// Use JMeter path for key file
	else if (key.equals(&quot;false&quot;)) {
		encodedKey = new String(Files.readAllBytes(Paths.get(filePath)), &quot;UTF-8&quot;);
	}

	// Use path relative to JMX path for key file
	else {
		encodedKey = new String(Files.readAllBytes(Paths.get(vars.get(&quot;keyPath&quot;) + File.separator + key + File.separator + filePath)), &quot;UTF-8&quot;);
	}
    byte[] decodedKey = Base64.getDecoder().decode(encodedKey)
    return new SecretKeySpec(decodedKey, 0, decodedKey.length, &quot;AES&quot;) 
}

// Main execution
String filePath = vars.get(&quot;keyFile&quot;)

// Load the key from the file
SecretKey key = loadKeyFromFile(filePath)

// Encrypt string
String unencryptedValue = vars.get(&quot;unencryptedValue&quot;)
String encryptedValue = encrypt(key, unencryptedValue)
log.info(&quot;Encrypted: &quot; + encryptedValue)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
      </hashTree>
    </hashTree>
  </hashTree>
